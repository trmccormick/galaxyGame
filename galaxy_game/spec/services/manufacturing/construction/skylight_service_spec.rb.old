require 'rails_helper'

RSpec.describe Construction::SkylightService, type: :service do
  # Use the terrestrial_planet factory with mars trait
  let!(:mars) { create(:terrestrial_planet, :mars) }
  
  # Use the celestial_location factory 
  let!(:lava_tube_location) { create(:celestial_location, 
    name: "Olympus Mons Lava Tube", 
    coordinates: "18.65°N 226.2°E", 
    celestial_body: mars
  )}
  
  # Create a player
  let!(:player) { create(:player) }
  
  # Create a settlement for the player at the location
  let!(:settlement) { create(:settlement, 
    :independent,
    name: "Olympus Base", 
    location: lava_tube_location,
    owner: player,
    settlement_type: :base,
    current_population: 15
  )}
  
  # Create a lava tube
  let!(:lava_tube) { 
    create(:lava_tube, 
      name: "Olympus Tube Alpha", 
      location: lava_tube_location,
      settlement: settlement,
      status: 'surveyed',
      diameter: 100,  # ADD THIS - make it bigger than skylight
      length: 500     # ADD THIS - make it long enough
    )
  }
  
  # Create a skylight
  let!(:skylight) { 
    create(:skylight, 
      diameter: 50,
      position: 0,
      lava_tube: lava_tube,
      status: 'uncovered'
    )
  }

  let!(:blueprint) do
    json = Lookup::BlueprintLookupService.new.find_blueprint('basic_transparent_crater_tube_cover_array')
    
    # Convert materials from JSON format to the format Blueprint expects
    input_resources = {}
    if json && json['materials']
      json['materials'].each do |material_name, material_data|
        # Extract quantity from the nested hash structure
        quantity = if material_data.is_a?(Hash)
          material_data['quantity_needed']&.split(' ')&.first&.to_i || 0
        else
          material_data.to_i
        end
        input_resources[material_name] = quantity
      end
    end
    
    Blueprint.create!(
      name: json['unit_id'] || 'basic_transparent_crater_tube_cover_array',
      description: json['description'],
      input_resources: input_resources,
      output_resources: {},
      production_time: 150, # 2.5 hours in minutes
      gcc_cost: 0,
      player: player,
      current_research_level: 0,
      material_efficiency: 1.0,
      time_efficiency: 1.0
    )
  end
  
  # Initialize the service with default panel type
  let(:service) { described_class.new(skylight) }
  let(:service_with_solar) { described_class.new(skylight, "solar_cover_panel") }

  # Setup before each test
  before do
    # Ensure inventory exists
    unless settlement.inventory
      settlement.create_inventory!
    end
    
    # Add materials using factory
    create(:item, 
      inventory: settlement.inventory, 
      name: "processed_regolith", 
      amount: 5000,
      material_type: 0,
      owner: settlement
    )
    
    create(:item, 
      inventory: settlement.inventory, 
      name: "aluminum_alloy", 
      amount: 2000,
      material_type: 0,
      owner: settlement
    )
    
    create(:item, 
      inventory: settlement.inventory, 
      name: "silicate_glass", 
      amount: 3000,
      material_type: 0,
      owner: settlement
    )
    
    create(:item, 
      inventory: settlement.inventory, 
      name: "3d_printed_ibeams", 
      amount: 500,
      material_type: 0,
      owner: settlement
    )
    
    # Mock service dependencies
    allow(MaterialRequestService).to receive(:create_material_requests_from_hash).and_return([double("MaterialRequest")])
    allow(EquipmentRequestService).to receive(:create_equipment_requests).and_return([double("EquipmentRequest")])
    
    # Mock Construction::SkylightCalculator
    allow(Construction::SkylightCalculator).to receive(:calculate_materials).and_return({
      "3d_printed_ibeams" => 231,
      "processed_regolith" => 17325,
      "aluminum_alloy" => 6930,
      "fasteners" => 924,
      "sealant" => 750
    })
    allow(Construction::SkylightCalculator).to receive(:calculate_panel_count).and_return(210)
    allow(Construction::SkylightCalculator).to receive(:calculate_printer_requirements).and_return({
      printer_count: 3,
      print_hours: 462,
      power_required: 150
    })
    allow(Construction::SkylightCalculator).to receive(:estimate_construction_time).and_return(1625)
  end

  describe "#initialize" do
    it "initializes with default panel type" do
      expect(service.instance_variable_get(:@panel_type)).to eq("basic_transparent_crater_tube_cover_array")
      expect(service.instance_variable_get(:@skylight)).to eq(skylight)
      expect(service.instance_variable_get(:@settlement)).to eq(settlement)
    end
    
    it "initializes with custom panel type" do
      solar_service = described_class.new(skylight, "solar_cover_panel", settlement)
      expect(solar_service.instance_variable_get(:@panel_type)).to eq("solar_cover_panel")
    end
    
    it "finds settlement from lava tube" do
      expect(service.instance_variable_get(:@settlement)).to eq(settlement)
    end
  end

  describe "#calculate_materials" do
    it "calculates materials for basic transparent panels" do
      materials = service.calculate_materials
      
      # Should include base materials from SkylightArrayCalculator
      expect(materials["3d_printed_ibeams"]).to eq(231)
      expect(materials["processed_regolith"]).to eq(17325)
      
      # Should include panel-specific materials
      expect(materials["silicate_glass"]).to be > 0
      expect(materials["aluminum_frame"]).to be > 0
    end
    
    it "calculates materials for solar panels" do
      materials = service_with_solar.calculate_materials
      
      # Should include solar-specific materials
      expect(materials["advanced_solar_cells"]).to eq(210 * 10) # 210 panels * 10kg each
      expect(materials["graphene_layers"]).to eq(210 * 3)
    end
  end

  describe "#schedule_construction" do
    it "creates a construction job successfully" do
      result = service.schedule_construction
      
      expect(result[:success]).to be true
      expect(result[:message]).to include("Construction scheduled")
      
      construction_job = result[:construction_job]
      expect(construction_job).to be_present
      expect(construction_job.jobable).to eq(skylight)
      expect(construction_job.job_type).to eq('skylight_cover')
      expect(construction_job.status).to eq('materials_pending')
      expect(construction_job.target_values['panel_type']).to eq("basic_transparent_crater_tube_cover_array")
    end
    
    it "fails when no settlement found" do
      service.instance_variable_set(:@settlement, nil)
      
      result = service.schedule_construction
      
      expect(result[:success]).to be false
      expect(result[:message]).to include("No settlement found")
    end
    
    it "updates skylight status to materials_requested" do
      service.schedule_construction
      
      expect(skylight.status).to eq("materials_requested")
      expect(skylight.panel_type).to eq("basic_transparent_crater_tube_cover_array")
    end
    
    it "creates material and equipment requests" do
      expect(MaterialRequestService).to receive(:create_material_requests_from_hash).and_call_original
      expect(EquipmentRequestService).to receive(:create_equipment_requests).and_call_original
      
      result = service.schedule_construction
      
      puts "Result: #{result.inspect}"
    end
  end

  describe "#start_construction" do
    let!(:construction_job) { 
      job = ConstructionJob.new(
        jobable: skylight,
        job_type: 'skylight_cover',
        status: 'materials_pending',
        settlement: settlement
      )
      
      job.target_values = { 
        panel_type: 'basic_transparent_crater_tube_cover_array',
        construction_phase: 'primary_installation'
      }
      
      job.save!
      job
    }
    
    before do
      # Mock ConstructionManager
      allow(Construction::ConstructionManager).to receive(:assign_builders).and_return(true)
      
      # Mock the materials_gathered? and equipment_gathered? methods
      allow(construction_job).to receive(:materials_gathered?).and_return(true)
      allow(construction_job).to receive(:equipment_gathered?).and_return(true)
    end
    
    it "starts construction when materials and equipment are ready" do
      result = service.start_construction(construction_job)
      
      expect(result).to be true
      expect(construction_job.status).to eq('in_progress')
      expect(skylight.status).to eq('under_construction')
      expect(skylight.estimated_completion).to be_present
    end
    
    it "fails when materials not ready" do
      allow(construction_job).to receive(:materials_gathered?).and_return(false)
      
      result = service.start_construction(construction_job)
      
      expect(result).to be false
      expect(construction_job.status).to eq('materials_pending')
    end
    
    it "fails when equipment not ready" do
      allow(construction_job).to receive(:equipment_gathered?).and_return(false)
      
      result = service.start_construction(construction_job)
      
      expect(result).to be false
    end
  end

  describe "#track_progress" do
    let!(:construction_job) { 
      job = ConstructionJob.new(
        jobable: skylight,
        job_type: 'skylight_cover',
        status: 'in_progress',
        settlement: settlement
      )
      
      job.target_values = { 
        panel_type: 'basic_transparent_crater_tube_cover_array'
      }
      
      job.save!
      job
    }
    
    before do
      allow(Construction::ConstructionManager).to receive(:complete?).and_return(true)
      allow(Construction::EquipmentManager).to receive(:release_equipment).and_return(true)
      allow(MaintenanceMonitorService).to receive(:start_repair_drones).and_return(true)
      allow(MaintenanceMonitorService).to receive(:start_advanced_maintenance).and_return(true)
    end
    
    it "completes construction when work is finished" do
      result = service.track_progress(construction_job)
      
      expect(result).to be true
      expect(construction_job.status).to eq('completed')
      expect(construction_job.completion_date).to be_present
      expect(skylight.status).to eq('primary_cover')
      expect(skylight.construction_date).to be_present
    end
    
    it "returns false when construction not complete" do
      allow(Construction::ConstructionManager).to receive(:complete?).and_return(false)
      
      result = service.track_progress(construction_job)
      
      expect(result).to be false
      expect(construction_job.status).to eq('in_progress')
    end
    
    it "sets correct status for different panel types" do
      # Test solar panel completion
      construction_job.target_values['panel_type'] = 'solar_cover_panel'
      construction_job.save!
      
      solar_service = described_class.new(skylight, 'solar_cover_panel', settlement)
      result = solar_service.track_progress(construction_job)
      
      expect(result).to be true
      expect(skylight.status).to eq('solar_cover')  # Don't reload - check in-memory
    end
  end

  describe "#calculate_construction_time" do
    it "calculates base time for transparent panels" do
      time = service.calculate_construction_time
      
      # Should be base time from calculator (1625) * 1.0 complexity
      expect(time).to eq(1625)
    end
    
    it "adjusts time for complex panel types" do
      solar_time = service_with_solar.calculate_construction_time
      
      # Should be base time * 1.5 complexity for solar panels
      expect(solar_time).to eq((1625 * 1.5).ceil)
    end
  end

  describe "#determine_completion_status" do
    it "returns correct status for primary cover" do
      status = service.send(:determine_completion_status, "basic_transparent_crater_tube_cover_array")
      expect(status).to eq("primary_cover")
    end
    
    it "returns correct status for solar cover" do
      status = service.send(:determine_completion_status, "solar_cover_panel")
      expect(status).to eq("solar_cover")
    end
    
    it "returns full_cover for secondary panel on primary cover" do
      skylight.update(status: "primary_cover")
      status = service.send(:determine_completion_status, "structural_cover_panel")
      expect(status).to eq("full_cover")
    end
  end

  describe "#calculate_equipment_requirements" do
    it "calculates equipment requirements based on skylight size" do
      requirements = service.calculate_equipment_requirements
      
      expect(requirements).to include(
        { equipment_type: "3d_printer", quantity: 3 },
        { equipment_type: "construction_drone", quantity: 4 },
        { equipment_type: "assembly_robot", quantity: 2 },
        { equipment_type: "materials_transport", quantity: 1 }
      )
    end
  end

  describe "panel-specific material calculations" do
    it "calculates thermal insulation materials" do
      thermal_service = described_class.new(skylight, "thermal_insulation_cover_panel")
      materials = thermal_service.send(:calculate_panel_specific_materials, "thermal_insulation_cover_panel")
      
      expect(materials["aerogel_layers"]).to eq(210 * 15) # 210 panels * 15kg each
      expect(materials["thermal_resistant_coating"]).to eq(210 * 5)
    end
    
    it "calculates structural panel materials" do
      structural_service = described_class.new(skylight, "structural_cover_panel")
      materials = structural_service.send(:calculate_panel_specific_materials, "structural_cover_panel")
      
      expect(materials["reinforced_steel"]).to eq(210 * 30)
      expect(materials["carbon_nanotubes"]).to eq(210 * 2)
    end
  end
end