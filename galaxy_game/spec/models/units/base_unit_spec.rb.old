        expect(lox_tank.store_resource('liquid_oxygen', 300)).to be false
      end

      it 'validates storage compatibility' do
        expect(lox_tank.store_resource('hematite', 100)).to be false
      end
    end

    describe '#requires_surface_storage?' do
      before do
        allow_any_instance_of(Lookup::MaterialLookupService)
          .to receive(:find_material)
          .with('processed_regolith')
          .and_return({ 'storage_requirements' => ['surface_storage'] })
      end

      it 'identifies materials requiring surface storage' do
        expect(regolith_processor.send(:requires_surface_storage?, 'processed_regolith')).to be true
      end
    end

    describe '#store_on_surface' do
      let(:surface_storage) { create(:surface_storage, settlement: base_settlement) }

      before do
        allow(base_settlement).to receive(:surface_storage).and_return(surface_storage)
        allow(surface_storage).to receive(:add_pile).and_return(true)
      end

      # it 'stores processed regolith on surface' do
      #   expect(regolith_processor.send(:store_on_surface, 'processed_regolith', 100)).to be true
