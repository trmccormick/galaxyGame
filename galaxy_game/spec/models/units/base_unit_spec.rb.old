    describe '#store_resource' do
      # it 'stores liquid oxygen in appropriate tank' do
      #   expect(lox_tank.store_resource('liquid_oxygen', 500)).to be true
      #   expect(lox_tank.current_storage_of('liquid_oxygen')).to eq(500)
