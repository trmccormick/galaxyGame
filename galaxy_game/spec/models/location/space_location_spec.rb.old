# spec/models/location/space_location_spec.rb
require 'rails_helper'

RSpec.describe Location::SpaceLocation, type: :model do
  describe 'associations' do
    it { is_expected.to belong_to(:solar_system).optional }
  end

  describe 'validations' do
    subject { build(:space_location) }

    it { is_expected.to validate_presence_of(:name) }
    it { is_expected.to validate_presence_of(:x_coordinate) }
    it { is_expected.to validate_presence_of(:y_coordinate) }
    it { is_expected.to validate_presence_of(:z_coordinate) }
    it { is_expected.to validate_uniqueness_of(:coordinates) }
    
    it { is_expected.to validate_numericality_of(:x_coordinate) }
    it { is_expected.to validate_numericality_of(:y_coordinate) }
    it { is_expected.to validate_numericality_of(:z_coordinate) }
  end

  describe '#update_location' do
    let(:space_location) { create(:space_location) }
    
    it 'updates coordinates' do
      new_coords = {
        x_coordinate: 100.0,
        y_coordinate: 200.0,
        z_coordinate: 300.0
      }
      
      expect(space_location.update_location(new_coords)).to be true
      expect(space_location.reload.x_coordinate).to eq(100.0)
      expect(space_location.reload.y_coordinate).to eq(200.0)
      expect(space_location.reload.z_coordinate).to eq(300.0)
    end
  end

  describe '#distance_to' do
    let(:location1) { create(:space_location, x_coordinate: 0, y_coordinate: 0, z_coordinate: 0) }
    let(:location2) { create(:space_location, x_coordinate: 3, y_coordinate: 4, z_coordinate: 0) }
    
    it 'calculates 3D distance between locations' do
      expect(location1.distance_to(location2)).to eq(5.0)
    end
  end
end