class GameDataGenerator
  # --- CONSTANTS ---
  DEFAULT_LLM_HOST = 'http://localhost:11434'
  DEFAULT_MODEL = 'llama3' # Or your preferred optimized model
  MAX_PROMPT_ENTITIES = 15 # The maximum number of entity IDs sent in the prompt for speed

  # --- INITIALIZATION ---
  def initialize(model = DEFAULT_MODEL)
    @host = ENV['LLM_HOST_URL'] || DEFAULT_LLM_HOST
    @model = model
    
    # --- FIX: Reverting to the most likely standard constant (Ollama::Client) ---
    # The previous errors (NameError: uninitialized constant OllamaAi) strongly
    # suggest a failure in the gem loading or a misnamed constant. 
    # This uses the most conventional naming for the 'ollama-ai' gem.
    @ollama_client = ::Ollama::Client.new(credentials: { host: @host })

    # Initialize all relevant lookup services
    @material_lookup_service = Lookup::MaterialLookupService.new
    @item_lookup_service = Lookup::ItemLookupService.new
    @blueprint_lookup_service = Lookup::BlueprintLookupService.new
    
    # Consolidate ALL known entity IDs for filtering
    @available_game_entities_for_prompt = collect_all_available_game_entities_for_prompt
  end

  # --- PUBLIC GENERATION METHODS ---
  
  # Main method to generate a new item based on a template
  def generate_item(template_path, output_path, params = {})
    template = load_template(template_path)
    json_content = generate_content_with_retry(template, params) 
    save_content(json_content, output_path)
    JSON.parse(json_content)
  end
  
  # Generate multiple items based on a list of specifications
  def batch_generate(template_path, specs)
    results = []
    
    specs.each do |spec|
      output_path = spec.delete(:output_path)
      result = generate_item(template_path, output_path, spec)
      results << result
    end
    
    results
  end

  def generate_structure(structure_type, category, name, description)
    # Load templates
    blueprint_template = GalaxyGame::Paths::TEMPLATE_PATH.join('structure_blueprint.json').to_s
    operational_template = GalaxyGame::Paths::TEMPLATE_PATH.join('structure_operational_data.json').to_s

    # Generate blueprint
    blueprint_params = {
      name: name,
      description: description,
      type: structure_type,
      category: category # NOTE: Added category parameter for filtering
    }
    
    blueprint_output_path = File.join(
      Rails.root.to_s, 
      GalaxyGame::Paths::STRUCTURE_BLUEPRINTS_PATH, 
      category, 
      "#{structure_type}_bp.json"
    )
    
    # Generate operational data
    operational_params = {
      name: name,
      description: "Operational data for #{name}",
      type: structure_type,
      category: category # NOTE: Added category parameter for filtering
    }
    
    operational_output_path = File.join(
      Rails.root.to_s, 
      GalaxyGame::Paths::STRUCTURES_PATH, 
      category, 
      "#{structure_type}.json"
    )
    
    # Generate both files
    blueprint = generate_item(blueprint_template, blueprint_output_path, blueprint_params)
    operational_data = generate_item(operational_template, operational_output_path, operational_params)
    
    [blueprint, operational_data]
  end

  # Generate a unit blueprint and operational data
  def generate_unit(unit_id, category, subcategory, properties = {})
    # ... (Implementation from your previous code remains the same) ...
    puts "\n🔍 Would generate unit: #{unit_id} (#{category}/#{subcategory})"

    blueprint_template = latest_template_file('unit_blueprint')
    operational_template = latest_template_file('unit_operational_data')

    # Mapping of categories for consistent naming
    category_to_blueprint_dir = {
      'power' => 'power',      
      'energy' => 'power',     
      'electronics' => 'electronics',
      'computers' => 'electronics', 
      'propulsion' => 'propulsion'
    }
    
    category_to_operational_dir = {
      'power' => 'energy',     
      'energy' => 'energy',    
      'electronics' => 'computers', 
      'computers' => 'computers',   
      'propulsion' => 'propulsion'
    }
    
    # Determine blueprint directory based on mapping
    blueprint_dir = category_to_blueprint_dir[category] || category
    blueprint_path = GalaxyGame::Paths::UNIT_BLUEPRINTS_PATH.join(blueprint_dir, "#{unit_id}_bp.json").to_s
    
    # Determine operational directory based on mapping
    operational_dir = category_to_operational_dir[category] || category
    
    # Select the appropriate operational path constant based on the mapped category
    operational_path = case operational_dir
    when 'energy'
      GalaxyGame::Paths::ENERGY_UNITS_PATH.join("#{unit_id}_data.json").to_s
    when 'computers'
      GalaxyGame::Paths::COMPUTER_UNITS_PATH.join("#{unit_id}_data.json").to_s
    when 'propulsion'
      GalaxyGame::Paths::PROPULSION_UNITS_PATH.join("#{unit_id}_data.json").to_s
    else
      GalaxyGame::Paths::UNITS_PATH.join(operational_dir, "#{unit_id}_data.json").to_s
    end
    
    # Generate the blueprint
    generate_item(
      blueprint_template,
      blueprint_path,
      {
        id: unit_id,
        name: format_unit_name(unit_id),
        category: category,
        subcategory: subcategory,
        description: properties[:description] || "A #{format_unit_name(unit_id).downcase} for spacecraft systems."
      }.merge(properties)
    )

    # Generate the operational data
    generate_item(
      operational_template,
      operational_path,
      {
        id: unit_id,
        name: format_unit_name(unit_id),
        category: category,
        subcategory: subcategory
      }.merge(properties)
    )

    [blueprint_path, operational_path]
  end

  # Generate a module blueprint and operational data
  def generate_module(module_id, category, subcategory, properties = {})
    # ... (Implementation from your previous code remains the same) ...
    puts "\n🔍 Would generate module: #{module_id} (#{category}/#{subcategory})"

    blueprint_template = latest_template_file('module_blueprint')
    operational_template = latest_template_file('module_operational_data')

    blueprint_dir = category
