# app/services/game_data_generator.rb

require 'ollama-ai'
require 'json'
require 'fileutils'
# require 'net/http' # REMOVED: Using the ollama-ai gem instead

# Ensure your lookup services and paths are loaded
# require_relative '../paths' 
# require_relative 'lookup/material_lookup_service'
# require_relative 'lookup/item_lookup_service'
