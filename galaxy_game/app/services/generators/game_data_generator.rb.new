        name: format_unit_name(module_id),
        category: category,
        subcategory: subcategory,
        description: properties[:description] || "A #{format_unit_name(module_id).downcase} module."
      }.merge(properties)
    )

    generate_item(
      operational_template,
      operational_path,
      {
        id: module_id,
        name: format_unit_name(module_id),
        category: category,
        subcategory: subcategory
      }.merge(properties)
