    [blueprint_path, operational_path]
  end

  # Generate a rig blueprint and operational data
  def generate_rig(rig_id, category, subcategory, properties = {})
    # ... (Implementation from your previous code remains the same) ...
    puts "\n🔍 Would generate rig: #{rig_id} (#{category}/#{subcategory})"

    blueprint_template = latest_template_file('rig_blueprint')
    operational_template = latest_template_file('rig_operational_data')

    blueprint_dir = category
    blueprint_path = GalaxyGame::Paths::RIG_BLUEPRINTS_PATH.join(blueprint_dir, "#{rig_id}_bp.json").to_s

    operational_dir = category
    operational_path = GalaxyGame::Paths::RIGS_PATH.join(operational_dir, "#{rig_id}_data.json").to_s

    generate_item(
      blueprint_template,
