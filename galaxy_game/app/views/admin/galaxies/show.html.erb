<%# Ensure admin card styles are loaded %>
<%= stylesheet_link_tag 'admin/admin_cards', media: 'all' %>
<div class="admin-main-container">
    <header class="admin-header">
        <h1 class="admin-title">GALAXY GAME - GALAXY ADMIN</h1>
        <div class="admin-header-info">
            Viewing: <%= @galaxy.name %> | <%= @solar_systems.count %> Solar Systems
        </div>
    </header>
    <aside class="admin-sidebar">
        <div class="admin-tool-section">
            <h3>🎯 ADMIN SECTIONS</h3>
            <a href="/admin" class="admin-tool-button">📊 Dashboard</a>
            <a href="/admin/galaxies" class="admin-tool-button admin-tool-button--active">🌌 Galaxies</a>
            <a href="/admin/solar_systems" class="admin-tool-button">☀️ Solar Systems</a>
            <a href="/admin/celestial_bodies" class="admin-tool-button">🌍 Celestial Bodies</a>
            <a href="/admin/organizations" class="admin-tool-button">🏢 Organizations</a>
            <a href="/admin/ai_manager/missions" class="admin-tool-button">🤖 AI Manager</a>
        </div>
        <div class="admin-tool-section">
            <h3>🔗 QUICK LINKS</h3>
            <a href="/admin/galaxies" class="admin-tool-button">🌌 All Galaxies</a>
        </div>
    </aside>
    <main class="admin-content">
        <section class="stats-section">
            <div class="stat-card">
                <div class="stat-value"><%= @solar_systems.count %></div>
                <div class="stat-label">Solar Systems</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= @solar_systems.joins(:celestial_bodies).count %></div>
                <div class="stat-label">Total Bodies</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= @solar_systems.joins(:stars).distinct.count %></div>
                <div class="stat-label">Systems with Stars</div>
            </div>
            <% if @galaxy.mass %>
                <div class="stat-card">
                    <div class="stat-value"><%= number_with_precision(@galaxy.mass, precision: 1) %></div>
                    <div class="stat-label">Mass (10^12 M☉)</div>
                </div>
            <% end %>
        </section>
        <section class="content-section">
            <h2 style="color: #00bfff; margin-bottom: 1.2rem;">☀️ Solar Systems</h2>
            <div class="admin-card-grid">
                <% @solar_systems.each do |system| %>
                    <div class="admin-card">
                        <div class="admin-card-header">
                            <div class="admin-card-title"><%= system.name %></div>
                            <div class="admin-card-type star"><%= system.stars.first&.type_of_star || 'No Star' %></div>
                        </div>
                        <div class="admin-card-description">
                            <%= system.celestial_bodies.count %> Bodies, <%= system.stars.count %> Stars
                        </div>
                        <div class="admin-card-details">
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">ID:</span>
                                <span class="admin-card-detail-value"><%= system.identifier %></span>
                            </div>
                            <% if system.stars.first %>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Star:</span>
                                    <span class="admin-card-detail-value"><%= system.stars.first.name %> (<%= system.stars.first.type_of_star || 'Unknown' %>)</span>
                                </div>
                            <% else %>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Star:</span>
                                    <span class="admin-card-detail-value">No central star detected</span>
                                </div>
                            <% end %>
                        </div>
                        <div class="admin-card-actions">
                            <a class="admin-action-btn primary" href="/admin/solar_systems/<%= system.id %>">View Details</a>
                            <a class="admin-action-btn" href="/solar_systems/<%= system.id %>">Public View</a>
                        </div>
                    </div>
                <% end %>
            </div>
            <% if @solar_systems.empty? %>
                <div class="admin-empty">
                    No solar systems in this galaxy.
                </div>
            <% end %>
        </section>
    </main>
</div>