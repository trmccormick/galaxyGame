
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Galaxy Game - Galaxies Admin</title>
    <%= stylesheet_link_tag 'admin/admin_cards', media: 'all' %>
</head>
<body>
<div class="admin-main-container">
    <header class="admin-header">
        <h1 class="admin-title">GALAXY GAME - GALAXIES ADMIN</h1>
        <div class="admin-header-info">
            Universe Overview: <%= @galaxy_stats[:total_galaxies] %> Galaxies | <%= @galaxy_stats[:total_systems] %> Solar Systems | Avg <%= @galaxy_stats[:avg_systems_per_galaxy] %> Systems/Galaxy
        </div>
    </header>
    <aside class="admin-sidebar">
        <div class="admin-tool-section">
            <h3>🎯 ADMIN SECTIONS</h3>
            <a href="/admin" class="admin-tool-button">📊 Dashboard</a>
            <a href="/admin/galaxies" class="admin-tool-button admin-tool-button--active">🌌 Galaxies</a>
            <a href="/admin/solar_systems" class="admin-tool-button">☀️ Solar Systems</a>
            <a href="/admin/celestial_bodies" class="admin-tool-button">🌍 Celestial Bodies</a>
            <a href="/admin/organizations" class="admin-tool-button">🏢 Organizations</a>
            <a href="/admin/ai_manager/missions" class="admin-tool-button">🤖 AI Manager</a>
        </div>
        <div class="admin-tool-section admin-galaxy-types">
            <h3 class="sidebar-section-title">📊 GALAXY TYPES</h3>
            <div class="type-breakdown">
                <div class="type-grid">
                    <% @galaxy_stats[:galaxy_types].each do |type, count| %>
                        <div class="type-item">
                            <div class="type-name"> <%= type %> </div>
                            <div class="type-count"> <%= count %> </div>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </aside>
    <main class="admin-content">
        <section class="stats-section">
            <div class="stat-card">
                <div class="stat-value"><%= @galaxy_stats[:total_galaxies] %></div>
                <div class="stat-label">Total Galaxies</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= @galaxy_stats[:total_systems] %></div>
                <div class="stat-label">Total Systems</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= @galaxy_stats[:avg_systems_per_galaxy] %></div>
                <div class="stat-label">Avg Systems/Galaxy</div>
            </div>
        </section>
        <section class="content-section">
            <h2 style="color: #00bfff; margin-bottom: 1.2rem;">🌌 Galaxies</h2>
            <div class="admin-card-grid">
                <% @galaxies.each do |galaxy| %>
                    <div class="admin-card">
                        <div class="admin-card-header">
                            <div class="admin-card-title"><%= galaxy.name %></div>
                            <div class="admin-card-type <%= galaxy.galaxy_type&.parameterize || 'unknown' %>"><%= galaxy.galaxy_type&.humanize || 'Unknown Type' %> Galaxy</div>
                        </div>
                        <div class="admin-card-description">
                            Identifier: <%= galaxy.identifier %><br>
                            <% if galaxy.mass %>
                                Mass: <%= number_with_precision(galaxy.mass, precision: 2) %> × 10^12 M☉<br>
                            <% end %>
                            Created: <%= galaxy.created_at.strftime('%Y-%m-%d') %>
                        </div>
                        <div class="admin-card-details">
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">Solar Systems:</span>
                                <span class="admin-card-detail-value"><%= galaxy.solar_systems.count %></span>
                            </div>
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">Total Bodies:</span>
                                <span class="admin-card-detail-value"><%= galaxy.solar_systems.joins(:celestial_bodies).count %></span>
                            </div>
                        </div>
                        <div class="admin-card-actions">
                            <a class="admin-action-btn primary" href="/admin/galaxies/<%= galaxy.id %>">View Systems</a>
                        </div>
                    </div>
                <% end %>
            </div>
            <% if @galaxies.empty? %>
                <div class="admin-empty">
                    No galaxies found.<br>
                    <button class="admin-tool-button" style="margin-top: 20px;" onclick="window.location.href='/simulation'">
                        Initialize Simulation
                    </button>
                </div>
            <% end %>
        </section>
    </main>
    </div>
</body>
</html>