<div class="admin-main-container" style="grid-template-columns: 250px 1fr;">
  <header class="admin-header">
    <h1 class="admin-title">ORGANIZATION MONITOR</h1>
    <div class="admin-header-info">
      <%= link_to "ADMIN", admin_dashboard_path %> &gt; <span>ORGANIZATIONS</span>
      <span class="admin-status-right"><span class="blink">●</span> <%= Time.current.strftime("%Y-%m-%d %H:%M:%S UTC") %></span>
    </div>
  </header>
  <aside class="admin-sidebar">
    <div class="admin-tool-section">
      <h3>🎯 ADMIN SECTIONS</h3>
      <a href="/admin" class="admin-tool-button">📊 Dashboard</a>
      <a href="/admin/galaxies" class="admin-tool-button">🌌 Galaxies</a>
      <a href="/admin/solar_systems" class="admin-tool-button">☀️ Solar Systems</a>
      <a href="/admin/celestial_bodies" class="admin-tool-button">🌍 Celestial Bodies</a>
      <a href="/admin/organizations" class="admin-tool-button admin-tool-button--active">🏢 Organizations</a>
      <a href="/admin/ai_manager/missions" class="admin-tool-button">🤖 AI Manager</a>
    </div>
  </aside>
  <main class="admin-content">
    <section class="stats-section">
      <div class="stat-card">
        <div class="stat-value"><%= @total_npc_count %></div>
        <div class="stat-label">NPC Organizations</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= @total_player_count %></div>
        <div class="stat-label">Player Organizations</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= @total_consortium_count %></div>
        <div class="stat-label">Consortiums</div>
      </div>
    </section>
    <% if @npc_organizations.any? %>
      <section class="content-section">
        <h2>▼ NPC ORGANIZATIONS</h2>
        <div class="admin-section-desc" style="margin-bottom: 32px;">AI-controlled corporations and development entities</div>
        <div class="dc-grid">
          <% @npc_organizations.each do |org| %>
            <%= render partial: 'org_card', locals: { org: org, settlements: @settlements_by_org[org.id] || [], contracts: (@active_contracts[org.id] || []).count } %>
          <% end %>
        </div>
      </section>
    <% end %>
    <% if @player_organizations.any? %>
      <section class="content-section">
        <h2>▼ PLAYER ORGANIZATIONS</h2>
        <div class="admin-section-desc">Player-owned corporations and enterprises</div>
        <div class="dc-grid">
          <% @player_organizations.each do |org| %>
            <%= render partial: 'org_card', locals: { org: org, settlements: @settlements_by_org[org.id] || [], contracts: (@active_contracts[org.id] || []).count } %>
          <% end %>
        </div>
      </section>
    <% end %>
    <% if @consortiums.any? %>
      <section class="content-section">
        <h2>▼ CONSORTIUMS</h2>
        <div class="admin-section-desc">Multi-corporate alliances and collaborative entities</div>
        <div class="dc-grid">
          <% @consortiums.each do |consortium| %>
            <%= render partial: 'org_card', locals: { org: consortium, settlements: @settlements_by_org[consortium.id] || [], contracts: (@active_contracts[consortium.id] || []).count } %>
          <% end %>
        </div>
      </section>
    <% end %>
    <% if @npc_organizations.empty? && @player_organizations.empty? && @consortiums.empty? %>
      <section class="content-section">
        <div class="admin-empty">
          <div class="admin-empty-title">NO ORGANIZATIONS FOUND</div>
          <div class="admin-empty-desc">
            No organizations have been initialized in the database.<br>
            Run <span style="color: #0f0;">rails db:seed</span> to create initial corporations.
          </div>
        </div>
      </section>
    <% end %>
  </main>
</div>
