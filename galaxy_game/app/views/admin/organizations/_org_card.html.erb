<div class="dc-card" style="margin-bottom: 32px;">
  <div style="display: flex; align-items: flex-start; gap: 32px;">
    <% logo_candidates = [] %>
    <% if org.respond_to?(:abbreviation) && org.abbreviation.present? %>
      <% logo_candidates << "logos/#{org.abbreviation}.png" %>
    <% end %>
    <% logo_candidates << "logos/#{org.name}.png" %>
    <% logo_candidates << "logos/#{org.identifier}.png" %>
    <% logo_path = logo_candidates.find { |path| asset_exists?(path) } %>
    <div style="flex: 0 0 200px; display: flex; align-items: center; justify-content: center; min-height: 140px;">
      <% if logo_path %>
        <%= image_tag logo_path, style: "max-width: 180px; max-height: 140px;", alt: org.name %>
      <% end %>
    </div>
    <div style="flex: 1 1 auto; min-width: 0;">
      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px;">
        <span style="font-size: 20px; color: #0ff; font-weight: bold;"> <%= org.name %> </span>
        <span style="font-size: 12px; color: #888;"> <%= org.identifier %> </span>
      </div>
      <div>
        <div class="dc-stat">
          <span class="dc-stat-label">Type:</span>
          <span class="dc-stat-value"><%= org.organization_type.to_s.titleize %></span>
        </div>
        <% if org.operational_data && org.operational_data['specialization'] %>
          <div class="dc-stat">
            <span class="dc-stat-label">Specialization:</span>
            <span class="dc-stat-value"><%= org.operational_data['specialization'].to_s.humanize %></span>
          </div>
        <% end %>
        <div class="dc-stat">
          <span class="dc-stat-label">GCC Balance:</span>
          <span class="dc-stat-value">
            <%= number_to_human(org.accounts.first&.balance || 0, precision: 2, units: { thousand: 'K', million: 'M', billion: 'B' }) %>
          </span>
        </div>
        <div class="dc-stat">
          <span class="dc-stat-label">Settlements:</span>
          <span class="dc-stat-value">
            <%= settlements.count %>
          </span>
        </div>
        <div class="dc-stat">
          <span class="dc-stat-label">Active Contracts:</span>
          <span class="dc-stat-value">
            <%= contracts %>
          </span>
        </div>
        <% if settlements.any? %>
          <div class="settlement-list">
            <div style="color: #0ff; font-size: 12px; margin-bottom: 5px;">BASES:</div>
            <% settlements.each do |settlement| %>
              <div class="settlement-item">
                ▸ <%= settlement.name %>
                <% if settlement.location %>
                  <span class="settlement-location">
                    @ <%= settlement.location.celestial_body&.name || settlement.location.name %>
                  </span>
                  <% if settlement.location.celestial_body_id %>
                    <%= link_to "[MONITOR]", admin_celestial_body_monitor_path(settlement.location.celestial_body_id), 
                        style: "color: #0ff; font-size: 10px; margin-left: 5px; text-decoration: none;" %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
