<%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
<%= stylesheet_link_tag 'application', media: 'all' %>

<div class="ai-manager-layout">
    <%# ── Sidebar ── %>
    <aside class="ai-manager-sidebar">
        <h3>🤖 AI Manager</h3>
        <%= link_to "📊 Dashboard",   admin_ai_manager_path,             class: "ai-manager-nav-link #{controller.action_name == 'index' ? 'active' : ''}" %>
        <%= link_to "🚀 Missions",    admin_ai_manager_missions_path,    class: "ai-manager-nav-link #{controller.action_name == 'missions' ? 'active' : ''}" %>
        <%= link_to "🧠 Decisions",   admin_ai_manager_decisions_path,   class: "ai-manager-nav-link #{controller.action_name == 'decisions' ? 'active' : ''}" %>
        <%= link_to "📋 Planner",     admin_ai_manager_planner_path,     class: "ai-manager-nav-link #{controller.action_name == 'planner' ? 'active' : ''}" %>
        <%= link_to "🎯 Patterns",    admin_ai_manager_patterns_path,    class: "ai-manager-nav-link #{controller.action_name == 'patterns' ? 'active' : ''}" %>
        <%= link_to "📈 Performance", admin_ai_manager_performance_path, class: "ai-manager-nav-link #{controller.action_name == 'performance' ? 'active' : ''}" %>
        <%= link_to "🧪 Testing",     "/admin/ai_manager/testing",       class: "ai-manager-nav-link #{controller.action_name == 'testing' ? 'active' : ''}" %>
        <h3>Admin</h3>
        <%= link_to "← Dashboard", admin_dashboard_path, class: "ai-manager-nav-link" %>
    </aside>

    <%# ── Header ── %>
    <header class="ai-manager-header">
        <h1>AI MANAGER — MISSION PATTERNS</h1>
        <div class="header-meta">
            System: <span class="status-ok">OPERATIONAL</span>
            Pattern Library: <span class="status-loaded">LOADED</span>
        </div>
    </header>

    <%# ── Main Content ── %>
    <main class="ai-manager-main">
        <section class="pattern-testing-section">
            <h2>🧠 PATTERN TESTING</h2>
            <div class="metrics-grid">
                <div class="stat-card">
                    <label>Pattern:</label>
                    <select class="test-select" id="patternSelect">
                        <option value="">Select Pattern...</option>
                        <option value="mars-terraforming">Mars Terraforming</option>
                        <option value="venus-industrial">Venus Industrial</option>
                        <option value="titan-fuel">Titan Fuel Mining</option>
                        <option value="asteroid-mining">Asteroid Mining</option>
                        <option value="europa-water">Europa Water Extraction</option>
                    </select>
                </div>
                <div class="stat-card">
                    <label>Tech Level (1-5):</label>
                </div>
                <%# ...existing content... %>
            </div>
        </section>
    </main>
</div>
                    <input type="number" class="test-input" id="techLevel" min="1" max="5" value="3">
                </div>
                <div class="stat-card">
                    <label>Budget (GCC):</label>
                    <input type="number" class="test-input" id="budget" min="100000" value="1000000">
                </div>
                <div class="stat-card" style="display: flex; flex-direction: column; justify-content: flex-end;">
                    <button class="admin-tool-button" onclick="testPattern()">Test Pattern</button>
                    <button class="admin-tool-button" onclick="loadPattern()">Load Pattern</button>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>🎯 AI MISSION PATTERNS</h2>
            <% if @patterns.empty? %>
                <div class="admin-section" style="text-align: center; padding: 40px;">
                    <div style="font-size: 48px; margin-bottom: 20px; color: #00d4ff;">🎯</div>
                    <div style="color: #888;">No AI patterns loaded.</div>
                    <div style="font-size: 12px; margin-top: 10px; color: #666;">
                        Mission patterns will be displayed here for testing and validation.
                    </div>
                </div>
            <% else %>
                <div class="metrics-grid">
                    <% @patterns.each do |pattern| %>
                        <div class="stat-card" style="min-width: 320px;">
                            <div class="pattern-header" style="display: flex; justify-content: space-between; align-items: center;">
                                <div class="pattern-name" style="font-weight: bold; font-size: 18px;"><%= pattern[:name] %></div>
                                <div class="pattern-status <%= pattern[:active] ? 'active' : 'inactive' %>" style="font-size: 12px;">
                                    <%= pattern[:active] ? 'ACTIVE' : 'INACTIVE' %>
                                </div>
                            </div>
                            <div class="pattern-description" style="margin-bottom: 10px; color: #0cf;"><%= pattern[:description] %></div>
                            <div class="pattern-details">
                                <div class="data-row"><span class="data-label">Target:</span> <span class="data-value"><%= pattern[:target_body] %></span></div>
                                <div class="data-row"><span class="data-label">Duration:</span> <span class="data-value"><%= pattern[:estimated_duration] %> years</span></div>
                                <div class="data-row"><span class="data-label">Complexity:</span> <span class="data-value"><%= pattern[:complexity] %></span></div>
                                <div class="data-row"><span class="data-label">Success Rate:</span> <span class="data-value"><%= pattern[:success_rate] %>%</span></div>
                            </div>
                            <div class="pattern-actions" style="margin-top: 10px;">
                                <button class="admin-tool-button" onclick="viewPattern('<%= pattern[:id] %>')">View Details</button>
                                <button class="admin-tool-button" onclick="testPattern('<%= pattern[:id] %>')">Test Run</button>
                                <% if pattern[:active] %>
                                    <button class="admin-tool-button danger" onclick="deactivatePattern('<%= pattern[:id] %>')">Deactivate</button>
                                <% else %>
                                    <button class="admin-tool-button" onclick="activatePattern('<%= pattern[:id] %>')">Activate</button>
                                <% end %>
                            </div>
                        </div>
                    <% end %>
                </div>
            <% end %>
        </section>

        <section class="content-section">
            <h2>📋 PATTERN TYPES</h2>
            <div class="admin-section">
                <div class="data-row"><span class="data-label">Terraforming Patterns:</span> <span class="data-value">Planetary transformation missions (Mars, Venus)</span></div>
                <div class="data-row"><span class="data-label">Resource Extraction:</span> <span class="data-value">Mining and harvesting operations (Titan, Asteroids, Europa)</span></div>
                <div class="data-row"><span class="data-label">Infrastructure:</span> <span class="data-value">Base building and orbital construction patterns</span></div>
                <div class="data-row"><span class="data-label">Research:</span> <span class="data-value">Scientific investigation and data collection missions</span></div>
            </div>
        </section>
    </main>
</div>

<script>
    function testPattern(patternId) {
        const pattern = patternId || document.getElementById('patternSelect').value;
        const techLevel = document.getElementById('techLevel').value;
        const budget = document.getElementById('budget').value;
        if (!pattern) {
            alert('Please select a pattern to test');
            return;
        }
        alert(`Testing pattern: ${pattern}\nTech Level: ${techLevel}\nBudget: ${budget} GCC`);
    }
    function loadPattern() {
        const pattern = document.getElementById('patternSelect').value;
        if (!pattern) {
            alert('Please select a pattern to load');
            return;
        }
        alert(`Loading pattern: ${pattern}`);
    }
    function viewPattern(patternId) {
        alert(`Viewing pattern details: ${patternId}`);
    }
    function activatePattern(patternId) {
        if (confirm(`Activate pattern: ${patternId}?`)) {
            alert(`Pattern activated: ${patternId}`);
            location.reload();
        }
    }
    function deactivatePattern(patternId) {
        if (confirm(`Deactivate pattern: ${patternId}?`)) {
            alert(`Pattern deactivated: ${patternId}`);
            location.reload();
        }
    }
</script>
