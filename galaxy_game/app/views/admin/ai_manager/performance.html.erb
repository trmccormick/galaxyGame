<div class="admin-main-container performance-page">
            <aside class="admin-sidebar">
                <div class="admin-tool-section">
                    <h3>🤖 AI MANAGER</h3>
                    <a href="/admin/ai_manager/missions" class="admin-tool-button">🚀 Missions</a>
                    <a href="/admin/ai_manager/decisions" class="admin-tool-button">🧠 Decisions</a>
                    <a href="/admin/ai_manager/planner" class="admin-tool-button">📋 Planner</a>
                    <a href="/admin/ai_manager/patterns" class="admin-tool-button">🎯 Patterns</a>
                    <a href="/admin/ai_manager/performance" class="admin-tool-button admin-tool-button--active">📊 Performance</a>
                </div>
                <div class="admin-tool-section">
                    <h3>🎯 ADMIN SECTIONS</h3>
                    <a href="/admin/dashboard" class="admin-tool-button">← Dashboard</a>
                </div>
            </aside>
            <header class="admin-header">
                <h1>GALAXY GAME - AI MANAGER PERFORMANCE</h1>
                <div class="admin-header-info">
                    System Status: <span class="text-success">OPERATIONAL</span> |
                    AI Performance: <span class="text-accent">MONITORING</span> |
                    Version: 1.0.0-alpha
                </div>
            </header>
            <main class="admin-content">
                <section class="content-section">
                    <h2>📊 AI PERFORMANCE METRICS</h2>
                    <div class="metrics-grid">
                        <div class="metric-card">
                            <div class="metric-label">Success Rate</div>
                            <div class="metric-value"><%= @metrics[:success_rate] %>%</div>
                            <div class="metric-trend positive">+2.1%</div>
                        </div>
                        <div class="metric-card">
                            <div class="metric-label">Avg Timeline</div>
                            <div class="metric-value"><%= @metrics[:average_timeline] %></div>
                            <div class="metric-trend neutral">±0.0%</div>
                        </div>
                        <div class="metric-card">
                            <div class="metric-label">Resource Efficiency</div>
                            <div class="metric-value"><%= @metrics[:resource_efficiency] %>%</div>
                            <div class="metric-trend positive">+5.3%</div>
                        </div>
                        <div class="metric-card">
                            <div class="metric-label">Active Missions</div>
                            <div class="metric-value">--</div>
                            <div class="metric-trend neutral">±0.0%</div>
                        </div>
                    </div>
                    <div class="controls-section">
                        <h3>🎛️ PERFORMANCE CONTROLS</h3>
                        <div class="control-group">
                            <span class="control-label">Decision Timeout:</span>
                            <input type="number" class="control-input" value="30" min="5" max="300">
                            <span class="control-hint">seconds</span>
                            <button class="control-btn">Update</button>
                        </div>
                        <div class="control-group">
                            <span class="control-label">Max Concurrent:</span>
                            <input type="number" class="control-input" value="5" min="1" max="20">
                            <span class="control-hint">missions</span>
                            <button class="control-btn">Update</button>
                        </div>
                        <div class="control-group">
                            <span class="control-label">Resource Threshold:</span>
                            <input type="number" class="control-input" value="85" min="50" max="95">
                            <span class="control-hint">percent</span>
                            <button class="control-btn">Update</button>
                        </div>
                    </div>
                    <div class="performance-chart">
                        📈 Performance Trends Chart (Coming Soon)
                    </div>
                    <h3>🚀 MISSION PERFORMANCE</h3>
                    <table class="performance-table">
                        <thead>
                            <tr>
                                <th>Mission</th>
                                <th>Status</th>
                                <th>Progress</th>
                                <th>Timeline</th>
                                <th>Efficiency</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="status-indicator good"></span>Mars Colony Alpha</td>
                                <td class="text-success">Active</td>
                                <td>67%</td>
                                <td>8.2 / 12 months</td>
                                <td>94%</td>
                                <td><button class="control-btn control-btn--small">Details</button></td>
                            </tr>
                            <tr>
                                <td><span class="status-indicator warning"></span>Venus Industrial Hub</td>
                                <td class="text-warning">Delayed</td>
                                <td>23%</td>
                                <td>4.1 / 18 months</td>
                                <td>78%</td>
                                <td><button class="control-btn control-btn--small">Details</button></td>
                            </tr>
                            <tr>
                                <td><span class="status-indicator good"></span>Titan Fuel Depot</td>
                                <td class="text-success">Completed</td>
                                <td>100%</td>
                                <td>6.8 / 7 months</td>
                                <td>96%</td>
                                <td><button class="control-btn control-btn--small">Review</button></td>
                            </tr>
                        </tbody>
                    </table>
                    <section class="content-section">
                        <h3>⚙️ SYSTEM HEALTH</h3>
                        <div class="system-health">
                            <div class="text-success"><span class="status-indicator good"></span><strong>Decision Engine:</strong> Operating normally</div>
                            <div class="text-success"><span class="status-indicator good"></span><strong>Pattern Library:</strong> All patterns loaded</div>
                            <div class="text-warning"><span class="status-indicator warning"></span><strong>Resource Monitor:</strong> High utilization detected</div>
                            <div class="text-success"><span class="status-indicator good"></span><strong>Mission Tracker:</strong> All missions accounted for</div>
                        </div>
                    </section>
                </section>
            </main>