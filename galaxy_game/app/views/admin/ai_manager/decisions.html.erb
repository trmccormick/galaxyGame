<%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
<%= stylesheet_link_tag 'application', media: 'all' %>



<div class="admin-main-container" style="grid-template-columns: 250px 1fr;">
  <header class="admin-header">
    <h1 class="studio-title">🧠 AI Manager Decisions</h1>
    <div class="studio-subtitle">Review and analyze all AI system decisions and outcomes</div>
  </header>
  <aside class="admin-sidebar">
    <section class="admin-tool-section">
      <h3>🤖 AI MANAGER</h3>
      <%= link_to '🚀 Missions', admin_ai_manager_missions_path, class: 'admin-tool-button' %>
      <%= link_to '🧠 Decisions', admin_ai_manager_decisions_path, class: 'admin-tool-button admin-tool-button--active' %>
      <%= link_to '📋 Planner', admin_ai_manager_planner_path, class: 'admin-tool-button' %>
      <%= link_to '🎯 Patterns', admin_ai_manager_patterns_path, class: 'admin-tool-button' %>
      <%= link_to '📊 Performance', admin_ai_manager_performance_path, class: 'admin-tool-button' %>
    </section>
    <section class="admin-tool-section">
      <h3>🎯 ADMIN SECTIONS</h3>
      <%= link_to '← Dashboard', admin_dashboard_path, class: 'admin-tool-button' %>
    </section>
  </aside>
  <main class="admin-content">
    <section class="content-section">
      <h2 class="activity-title">🧠 AI DECISION LOG</h2>
      <div class="stats-section">
        <div class="stat-card">
          <div class="stat-value">--</div>
          <div class="stat-label">Total Decisions</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">--</div>
          <div class="stat-label">Success Rate</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">--</div>
          <div class="stat-label">Avg Response Time</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">--</div>
          <div class="stat-label">Active Decisions</div>
        </div>
      </div>
      <div class="recent-activity" id="decisionLog">
        <% if @decisions.empty? %>
          <div class="activity-item" style="text-align: center; color: #666; padding: 40px; flex-direction: column;">
            <div style="font-size: 48px; margin-bottom: 20px;">🧠</div>
            <div>No AI decisions logged yet.</div>
            <div style="font-size: 12px; margin-top: 10px;">Decision tracking will appear here as the AI makes operational choices.</div>
          </div>
        <% else %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Time</th>
                <th>Celestial Body</th>
                <th>Location</th>
                <th>Type</th>
                <th>Reasoning</th>
                <th>Constraints</th>
                <th>Outcome</th>
                <th>Lessons Learned</th>
              </tr>
            </thead>
            <tbody>
              <% @decisions.each do |log| %>
                <tr>
                  <td><%= log.created_at.strftime('%Y-%m-%d %H:%M') %></td>
                  <td><%= log.celestial_body&.name %></td>
                  <td><%= log.location_context %></td>
                  <td><%= log.decision_type %></td>
                  <td><%= log.reasoning %></td>
                  <td><%= log.constraints.is_a?(Hash) ? log.constraints.to_json : log.constraints %></td>
                  <td><%= log.outcome.is_a?(Hash) ? log.outcome.to_json : log.outcome %></td>
                  <td><%= (log.metadata['lessons_learned'] if log.metadata).presence || '-' %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </section>
    <section class="content-section">
      <h3>📋 DECISION TYPES</h3>
      <div class="mission-details" style="background: #0a0a0a; padding: 15px; border: 1px solid #333; margin-top: 10px;">
        <div style="color: #0f0;"><strong>Resource Allocation:</strong> AI deciding how to distribute limited resources across competing needs</div>
        <div style="color: #888;"><strong>Contract Negotiation:</strong> AI evaluating and negotiating supply contracts with NPCs</div>
        <div style="color: #888;"><strong>Mission Planning:</strong> AI making strategic decisions about mission priorities and timelines</div>
        <div style="color: #888;"><strong>Settlement Operations:</strong> AI managing day-to-day settlement activities and optimizations</div>
      </div>
    </section>
  </main>
</div>
