<%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
<%= stylesheet_link_tag 'application', media: 'all' %>

<div class="admin-main-container" style="grid-template-columns: 250px 1fr;">
  <header class="admin-header">
    <h1>AI MANAGER - MISSION PLANNER</h1>
    <div class="admin-header-info">
      <%= link_to '◄ Back to Missions', admin_ai_manager_missions_path, class: 'admin-dashboard-link' %> | MISSION PLANNER
    </div>
  </header>
  <aside class="admin-sidebar">
    <section class="admin-tool-section">
      <h3>🤖 AI MANAGER</h3>
      <%= link_to '📋 Missions', admin_ai_manager_missions_path, class: 'admin-tool-button' %>
      <%= link_to '🎯 Planner', admin_ai_manager_planner_path, class: 'admin-tool-button' %>
      <%= link_to '🗺️ Map Studio', admin_map_studio_path, class: 'admin-tool-button' %>
      <%= link_to '🧠 Decisions', admin_ai_manager_decisions_path, class: 'admin-tool-button' %>
      <%= link_to '🔬 Patterns', admin_ai_manager_patterns_path, class: 'admin-tool-button' %>
      <%= link_to '📊 Performance', admin_ai_manager_performance_path, class: 'admin-tool-button' %>
    </section>
  </aside>
  <main class="admin-content">
    <div class="admin-section">
      <h3>Simulation Config</h3>
      <%= form_with url: admin_ai_manager_planner_path, method: :get, local: true do |f| %>
        <div class="form-group">
          <label>MISSION PATTERN:</label>
          <%= select_tag :pattern, options_for_select(@available_patterns.map { |p| [p.upcase, p] }, params[:pattern]), prompt: "Select Pattern..." %>
        </div>
        <div class="form-group">
          <label>TECH LEVEL:</label>
          <%= select_tag :tech_level, options_for_select([
            ['STANDARD (Current Tech)', 'standard'],
            ['ADVANCED (+10 Years)', 'advanced'],
            ['EXPERIMENTAL (+20 Years)', 'experimental']
          ], params[:tech_level] || 'standard') %>
        </div>
        <div class="form-group">
          <label>TIMELINE (Years):</label>
          <%= number_field_tag :timeline_years, params[:timeline_years] || 10, min: 5, max: 50 %>
        </div>
        <div class="form-group">
          <label>BUDGET (GCC):</label>
          <%= number_field_tag :budget_gcc, params[:budget_gcc] || 1_000_000, min: 100_000, step: 100_000 %>
        </div>
        <div class="form-group">
          <label>PRIORITY:</label>
          <%= select_tag :priority, options_for_select([
            ['BALANCED', 'balanced'],
            ['SPEED (Fast Timeline)', 'speed'],
            ['EFFICIENCY (Low Cost)', 'efficiency'],
            ['RELIABILITY (High Success)', 'reliability']
          ], params[:priority] || 'balanced') %>
        </div>
        <%= submit_tag 'RUN SIMULATION', class: 'admin-tool-button' %>
      <% end %>
      <% if @simulation_result.present? %>
        <div style="margin-top: 20px;">
          <%= button_to 'EXPORT PLAN (JSON)', 
            admin_ai_manager_export_plan_path(
              pattern: params[:pattern],
              parameters: {
                tech_level: params[:tech_level],
                timeline_years: params[:timeline_years],
                budget_gcc: params[:budget_gcc],
                priority: params[:priority]
              }.to_json
            ),
            method: :post,
            class: 'admin-tool-button'
          %>
        </div>
      <% end %>
    </div>
    <div class="admin-section">
      <h3>Simulation Results</h3>
      <% if @simulation_result && @simulation_result[:local_capabilities] %>
        <div class="precursor-status-banner">
          <% capabilities = @simulation_result[:local_capabilities] %>
          <% if capabilities[:available] %>
            <div class="status-box enabled">
              <h4>✅ Precursor Infrastructure: ACTIVE</h4>
              <p>Location: <%= capabilities[:location] %></p>
              <p>Local Resources: <%= capabilities[:atmosphere].size + capabilities[:surface].size %> types available</p>
              <p class="savings">💰 Precursor Savings: <%= number_to_human(@simulation_result[:costs][:precursor_total_savings], precision: 2, units: { thousand: 'K', million: 'M', billion: 'B' }) %> GCC</p>
            </div>
          <% else %>
            <div class="status-box warning">
              <h4>⚠️ No Precursor Infrastructure</h4>
              <p>All resources must be imported from Earth</p>
              <% if @simulation_result[:sourcing_strategy][:precursor_recommendation] %>
                <% rec = @simulation_result[:sourcing_strategy][:precursor_recommendation] %>
                <p class="recommendation">
                  <strong>Recommendation:</strong> <%= rec[:payback_analysis][:recommendation] %>
                </p>
                <p>Potential Savings: <%= number_to_human(rec[:estimated_savings], precision: 2, units: { thousand: 'K', million: 'M', billion: 'B' }) %> GCC</p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
      <% if @simulation_result.present? %>
        <div class="results-section">
          <h3>▸ TIMELINE</h3>
          <div class="stat-line">Duration: <%= @simulation_result[:timeline][:total_years] %> years</div>
          <div class="stat-line">Phases: <%= @simulation_result[:timeline][:phases].size %></div>
          <% @simulation_result[:timeline][:phases].each do |phase| %>
            <div class="stat-line">  • <%= phase[:name] %>: <%= phase[:duration] %> years</div>
          <% end %>
        </div>
        <div class="results-section">
          <h3>▸ TOTAL COST</h3>
          <div class="stat-line">Base Cost: <%= number_to_human(@simulation_result[:costs][:total_gcc], precision: 2) %> GCC</div>
          <div class="stat-line">Contingency: <%= number_to_human(@simulation_result[:costs][:contingency], precision: 2) %> GCC</div>
          <div class="stat-line highlight">Grand Total: <%= number_to_human(@simulation_result[:costs][:grand_total], precision: 2) %> GCC</div>
          <% if @simulation_result[:costs][:breakdown].present? %>
            <h4>Resource Breakdown</h4>
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Resource</th>
                  <th>Source</th>
                  <th>Quantity</th>
                  <th>Unit Cost</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% @simulation_result[:costs][:breakdown].each do |resource, details| %>
                  <tr class="<%= details[:source_type] %>-resource">
                    <td><%= resource %> <% if details[:chemical_formula] %>(<%= details[:chemical_formula] %>)<% end %></td>
                    <td class="source-<%= details[:source_type] %>"><%= details[:source] %></td>
                    <td><%= number_with_delimiter(details[:quantity]) %></td>
                    <td><%= number_to_currency(details[:unit_cost], unit: "GCC ") %></td>
                    <td><%= number_to_currency(details[:total], unit: "GCC ") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% end %>
        </div>
        <div class="results-section">
          <h3>▸ PLAYER OPPORTUNITIES</h3>
          <div class="stat-line highlight">Total Revenue: <%= number_to_human(@simulation_result[:player_revenue][:total_opportunity_gcc], precision: 2) %> GCC</div>
          <div class="stat-line">Contracts: ~<%= @simulation_result[:player_revenue][:contract_count] %></div>
          <div class="stat-line">Avg Value: <%= number_to_human(@simulation_result[:player_revenue][:average_contract_value], precision: 2) %> GCC</div>
        </div>
        <div class="results-section">
          <h3>▸ RESOURCE REQUIREMENTS</h3>
          <div class="stat-line">Peak Demand: Year <%= @simulation_result[:resources][:peak_demand][:year] %></div>
          <div class="resource-list">
            <% @simulation_result[:resources][:total].sort_by { |_, qty| -qty }.first(10).each do |resource, quantity| %>
              <div class="resource-item">
                <%= resource.ljust(20) %> <%= number_to_human(quantity, precision: 0) %> units
              </div>
            <% end %>
          </div>
        </div>
        <% if @simulation_result[:planetary_changes].present? %>
          <div class="results-section">
            <h3>▸ PLANETARY CHANGES</h3>
            <% @simulation_result[:planetary_changes].each do |category, changes| %>
              <div class="stat-line highlight"><%= category.to_s.upcase %>:</div>
              <% if changes.is_a?(Hash) %>
                <% changes.each do |key, value| %>
                  <div class="stat-line">  <%= key.to_s.humanize %>: <%= value %></div>
                <% end %>
              <% else %>
                <div class="stat-line">  <%= changes %></div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="admin-empty">▶ SELECT PATTERN AND RUN SIMULATION</div>
      <% end %>
    </div>
    <div class="admin-section">
      <h3>Economic Forecast</h3>
      <% if @forecast.present? %>
        <div class="results-section">
          <h3>▸ GCC FLOW ANALYSIS</h3>
          <div class="stat-line">Total Project: <%= number_to_human(@forecast[:gcc_distribution][:total_project_cost], precision: 2) %> GCC</div>
          <div class="stat-line">DC Expenditure: <%= @forecast[:gcc_distribution][:dc_percentage] %>%</div>
          <div class="stat-line highlight">Player Earnings: <%= @forecast[:gcc_distribution][:player_percentage] %>%</div>
          <div class="stat-line">Economic Velocity: <%= number_to_human(@forecast[:gcc_distribution][:economic_velocity], precision: 2) %> GCC/year</div>
        </div>
        <div class="results-section">
          <h3>▸ DEMAND FORECAST</h3>
          <div class="stat-line">Trend: <%= @forecast[:demand_forecast][:demand_curve][:trend].upcase %></div>
          <div class="stat-line">Peak: Year <%= @forecast[:demand_forecast][:peak_demand][:year] %> (<%= number_to_human(@forecast[:demand_forecast][:peak_demand][:total_units]) %> units)</div>
          <div class="stat-line">Critical Resources: <%= @forecast[:demand_forecast][:critical_resources].size %></div>
        </div>
        <% if @forecast[:bottlenecks].any? %>
          <div class="results-section">
            <h3>▸ BOTTLENECKS (<%= @forecast[:bottlenecks].size %>)</h3>
            <% @forecast[:bottlenecks].first(3).each do |bottleneck| %>
              <div class="bottleneck">
                <div class="stat-line highlight">
                  <%= bottleneck[:resource] || "Year #{bottleneck[:year]}" %> [<%= bottleneck[:severity].upcase %>]
                </div>
                <div class="stat-line" style="font-size: 11px;">
                  <%= bottleneck[:recommendation] %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if @forecast[:opportunities].any? %>
          <div class="results-section">
            <h3>▸ OPPORTUNITIES (<%= @forecast[:opportunities].size %>)</h3>
            <% @forecast[:opportunities].first(3).each do |opp| %>
              <div class="opportunity">
                <div class="stat-line highlight">
                  <%= opp[:type].upcase.gsub('_', ' ') %>
                </div>
                <div class="stat-line" style="font-size: 11px;">
                  <%= opp[:description] %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if @forecast[:risk_assessment].any? %>
          <div class="results-section">
            <h3>▸ RISK ASSESSMENT</h3>
            <% @forecast[:risk_assessment].each do |risk| %>
              <div class="risk">
                <div class="stat-line highlight">
                  <%= risk[:category].upcase %> [<%= risk[:severity].upcase %>]
                </div>
                <div class="stat-line" style="font-size: 11px;">
                  <%= risk[:description] %>
                </div>
                <div class="stat-line highlight" style="font-size: 11px;">
                  ▸ <%= risk[:mitigation] %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="admin-empty">▶ AWAITING SIMULATION DATA</div>
      <% end %>
    </div>
  </main>
</div>
