<div class="ai-manager-layout">
    <%# ── Sidebar ── %>
    <aside class="ai-manager-sidebar">
        <h3>🤖 AI Manager</h3>
        <%= link_to "📊 Dashboard",   admin_ai_manager_path,             class: "ai-manager-nav-link #{controller.action_name == 'index' ? 'active' : ''}" %>
        <%= link_to "🚀 Missions",    admin_ai_manager_missions_path,    class: "ai-manager-nav-link #{controller.action_name == 'missions' ? 'active' : ''}" %>
        <%= link_to "🧠 Decisions",   admin_ai_manager_decisions_path,   class: "ai-manager-nav-link #{controller.action_name == 'decisions' ? 'active' : ''}" %>
        <%= link_to "📋 Planner",     admin_ai_manager_planner_path,     class: "ai-manager-nav-link #{controller.action_name == 'planner' ? 'active' : ''}" %>
        <%= link_to "🎯 Patterns",    admin_ai_manager_patterns_path,    class: "ai-manager-nav-link #{controller.action_name == 'patterns' ? 'active' : ''}" %>
        <%= link_to "📈 Performance", admin_ai_manager_performance_path, class: "ai-manager-nav-link #{controller.action_name == 'performance' ? 'active' : ''}" %>
        <%= link_to "🧪 Testing",     "/admin/ai_manager/testing",       class: "ai-manager-nav-link #{controller.action_name == 'testing' ? 'active' : ''}" %>
        <h3>Admin</h3>
        <%= link_to "← Dashboard", admin_dashboard_path, class: "ai-manager-nav-link" %>
    </aside>

    <%# ── Header ── %>
    <header class="ai-manager-header">
        <h1>AI MANAGER — MISSIONS</h1>
        <div class="header-meta">
            System: <span class="status-ok">OPERATIONAL</span>
        </div>
    </header>

    <%# ── Main Content ── %>
    <main class="ai-manager-main">
        <%# PAGE CONTENT GOES HERE %>
        <section class="stats-section">
            <div class="stat-card">
                <div class="stat-value"><%= @active_missions_count %></div>
                <div class="stat-label">Active Missions</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= @completed_missions_count %></div>
                <div class="stat-label">Completed Missions</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= @failed_missions_count %></div>
                <div class="stat-label">Failed Missions</div>
            </div>
        </section>
        <%# ...existing content... %>
    </main>
</div>
        <main class="admin-content">
            <% if @missions.any? %>
                <% if @active_missions.any? %>
                    <section class="admin-section">
                        <h3>⚡ ACTIVE MISSIONS</h3>
                        <% @active_missions.each do |mission| %>
                            <div class="admin-mission-card active" onclick="window.location.href='<%= admin_ai_manager_mission_path(mission) %>'">
                                <h4><%= mission.identifier.upcase %></h4>
                                <div class="admin-mission-details">
                                    <div class="data-row"><span class="data-label">Settlement:</span><span class="data-value"><%= mission.settlement&.name || 'N/A' %></span></div>
                                    <div class="data-row"><span class="data-label">Progress:</span><span class="data-value"><%= mission.progress %>%</span></div>
                                    <div class="data-row"><span class="data-label">Status:</span><span class="data-value"><%= mission.status.titleize %></span></div>
                                    <div class="data-row"><span class="data-label">Type:</span><span class="data-value"><%= mission.mission_type || 'Unknown' %></span></div>
                                </div>
                                <div class="admin-progress-bar"><div class="admin-progress-fill" style="width: <%= mission.progress %>%"></div></div>
                            </div>
                        <% end %>
                    </section>
                <% end %>
                <% if @completed_missions.any? %>
                    <section class="admin-section">
                        <h3>✅ COMPLETED MISSIONS</h3>
                        <% @completed_missions.limit(5).each do |mission| %>
                            <div class="admin-mission-card completed" onclick="window.location.href='<%= admin_ai_manager_mission_path(mission) %>'">
                                <span class="mission-id"><%= mission.identifier %></span>
                                <span class="mission-date"><%= mission.completion_date&.strftime('%Y-%m-%d') || 'N/A' %></span>
                            </div>
                        <% end %>
                    </section>
                <% end %>
                <% if @failed_missions.any? %>
                    <section class="admin-section">
                        <h3 class="failed">⚠️ FAILED/STALLED MISSIONS</h3>
                        <% @failed_missions.limit(5).each do |mission| %>
                            <div class="admin-mission-card failed" onclick="window.location.href='<%= admin_ai_manager_mission_path(mission) %>'">
                                <span class="mission-id"><%= mission.identifier %></span>
                                <span class="mission-status"><%= mission.status.titleize %></span>
                            </div>
                        <% end %>
                    </section>
                <% end %>
            <% else %>
                <section class="admin-section">
                    <h3>📭 NO MISSIONS FOUND</h3>
                    <p class="admin-empty">No missions exist in the database yet. Missions will appear here once they are created by the AI Manager.</p>
                </section>
            <% end %>
        </main>
        <aside class="admin-activity-log">
            <section class="admin-tool-section">
                <h3>📜 AI ACTIVITY LOG</h3>
                <div class="admin-activity-list">
                    <% @missions.limit(10).each do |mission| %>
                        <div class="admin-activity-item">
                            <div class="activity-time"><%= mission.created_at.strftime('%H:%M:%S') %></div>
                            <div class="activity-id"><%= mission.identifier %></div>
                            <div class="activity-status"><%= mission.status.titleize %> - <%= mission.progress %>%</div>
                        </div>
                    <% end %>
                </div>
            </section>
        </aside>
    </div>
</body>
</html>
