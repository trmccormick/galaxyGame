<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Surface View - <%= @celestial_body.name %></title>
    <%= stylesheet_link_tag 'admin/monitor', media: 'all' %>
</head>
<body>
    <%# Data injection - identical to monitor but surface-focused %>
    <script type="application/json" id="surface-data">
    <%
      terrain_map_data = @celestial_body&.geosphere&.terrain_map
      has_hydrosphere = @celestial_body.hydrosphere.present? && (
          @celestial_body.hydrosphere.state_distribution&.dig('liquid').to_f > 0 ||
          (@celestial_body.hydrosphere.liquid_type.present? && @celestial_body.hydrosphere.liquid_type.to_s.downcase != 'none')
      )
      
      surface_data = {
        planet_id: @celestial_body.id,
        planet_name: @celestial_body.name,
        planet_type: @celestial_body.type,
        surface_temperature: @celestial_body.surface_temperature,
        gravity: @celestial_body.gravity,
        radius: @celestial_body.radius,
        tileset_name: @tileset_name || 'trident',
        
        # Terrain data (core for surface view)
        terrain_data: terrain_map_data ? {
          elevation: terrain_map_data['elevation'] || terrain_map_data['grid'],
          biomes: terrain_map_data['biomes'],
          resources: terrain_map_data['resource_grid'],
          width: terrain_map_data['width'],
          height: terrain_map_data['height'] || (terrain_map_data['elevation']&.length || 0),
          quality_score: terrain_map_data['quality_score'],
          generation_method: terrain_map_data['generation_method']
        } : nil,
        
        # Sphere data (same as monitor for consistency)
        planet_data: {
          name: @celestial_body.name,
          type: @celestial_body.type,
          atmosphere: @celestial_body.atmosphere&.attributes,
          surface_temperature: @celestial_body.surface_temperature,
          temperature: @celestial_body.temperature,
          geological_activity: @celestial_body.geological_activity,
          gravity: @celestial_body.gravity,
          liquid_name: @celestial_body.hydrosphere&.liquid_type || 'H2O',
          water_coverage: @celestial_body.hydrosphere&.state_distribution&.dig('liquid') || 0,
          has_hydrosphere: has_hydrosphere
        },
        
        # Layer availability (surface-specific)
        available_layers: {
          terrain: true,
          grid: true,
          features: true,
          settlements: true,  # Game layer
          resources: true
        }
      }
    %>
    <%= raw surface_data.to_json %>
    </script>

    <div class="admin-main-container" style="display: grid; grid-template-columns: 250px 1fr 320px; grid-template-rows: auto 1fr auto; min-height: 100vh;">
        
        <!-- Header (surface-specific) -->
        <header class="admin-header" style="grid-column: 1 / span 3;">
            <h1 class="admin-title"><%= @celestial_body.name %> - SURFACE VIEW</h1>
            <div class="admin-header-info">
                <%= @celestial_body.type %> |
                Tileset: <span id="current-tileset"><%= @tileset_name || 'trident' %></span> |
                Radius: <%= number_to_human(@celestial_body.radius, precision: 2) %> m |
                Gravity: <%= number_with_precision(@celestial_body.gravity, precision: 3) %>g |
                Temp: <%= number_with_precision(@celestial_body.surface_temperature, precision: 1) %>K |
                <%= link_to '← Monitor', monitor_admin_celestial_body_path(@celestial_body), style: 'color: #00d4ff; margin-left: 20px;' %>
            </div>
        </header>

        <!-- Left Sidebar (surface navigation + tileset selector) -->
        <aside class="admin-sidebar">
            <!-- Navigation -->
            <div class="admin-tool-section">
                <h3>🎯 NAVIGATION</h3>
                <%= link_to '🖥️ Monitor View', monitor_admin_celestial_body_path(@celestial_body), class: 'admin-tool-button' %>
                <%= link_to '⚙️ Edit Properties', edit_admin_celestial_body_path(@celestial_body), class: 'admin-tool-button' %>
                <%= link_to '🌍 Celestial Bodies', admin_celestial_bodies_path, class: 'admin-tool-button' %>
            </div>

            <!-- Tileset Selector (surface-specific) -->
            <div class="admin-tool-section">
                <h3>🧩 TILESET</h3>
                <select id="tilesetSelect" class="admin-input">
                    <option value="trident" <%= 'selected' if @tileset_name == 'trident' %>>Trident</option>
                    <option value="alio" <%= 'selected' if @tileset_name == 'alio' %>>Alio (Sci-Fi)</option>
                    <option value="bigtrident" <%= 'selected' if @tileset_name == 'bigtrident' %>>BigTrident</option>
                    <option value="hexemplar" <%= 'selected' if @tileset_name == 'hexemplar' %>>Hexemplar</option>
                    <option value="isophex" <%= 'selected' if @tileset_name == 'isophex' %>>Isophex</option>
                </select>
                <button id="reloadTilesetBtn" class="admin-tool-button">🔄 Reload Tileset</button>
            </div>

            <!-- Map Layers (surface version) -->
            <div class="admin-tool-section">
                <h3>🗺️ SURFACE LAYERS</h3>
                <div class="layer-selector">
                    <button class="layer-btn active" data-layer="terrain">Terrain</button>
                    <button class="layer-btn" data-layer="grid">Grid</button>
                    <button class="layer-btn" data-layer="features">Features</button>
                    <button class="layer-btn" data-layer="settlements">Settlements</button>
                    <button class="layer-btn" data-layer="resources">Resources</button>
                </div>
            </div>
        </aside>

        <!-- Main: Surface Canvas (identical structure to monitor) -->
        <main class="admin-content" style="padding: 0 2rem;">
            <div id="canvasWrapper">
                <div id="mapOverlay">
                    <div id="mapTitle"><%= @celestial_body.name %> - SURFACE MAP</div>
                </div>
                <div id="canvasScroller" style="overflow: auto; width: 100%; height: 100%;">
                    <div id="canvasContainer" style="min-width: 1200px; min-height: 600px;">
                        <canvas id="surfaceCanvas" width="2400" height="1200"></canvas>
                    </div>
                </div>
                <div id="featureTooltip" class="hidden">
                    <div id="tooltipContent"></div>
                </div>
                <div id="mapControls" style="width: 100%; display: flex; justify-content: flex-end; align-items: center; gap: 2rem; margin-top: 0.5rem;">
                    <div class="control-group">
                        <label>Zoom: <span id="zoomValue" class="value-display">1.0x</span></label>
                        <input type="range" id="zoom" min="0.5" max="6" step="0.1" value="1">
                    </div>
                    <button id="resetViewBtn" class="admin-tool-button" title="Reset view">⌂ Reset</button>
                </div>
            </div>
        </main>

        <!-- Right Panel: Surface Data (tileset status + cursor info) -->
        <aside id="dataPanel">
            <!-- Tileset Status -->
            <div class="data-section">
                <h3>🧩 TILESET STATUS</h3>
                <div class="data-row">
                    <span class="data-label">Name:</span>
                    <span class="data-value" id="tileset-name">Loading...</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Tiles Loaded:</span>
                    <span class="data-value" id="tiles-loaded">0</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Status:</span>
                    <span class="data-value" id="tileset-status">Initializing...</span>
                </div>
            </div>

            <!-- Cursor Info -->
            <div class="data-section">
                <h3>📍 CURSOR</h3>
                <div class="data-row">
                    <span class="data-label">Position:</span>
                    <span class="data-value" id="cursor-pos">-</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Tile:</span>
                    <span class="data-value" id="cursor-tile">-</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Biome:</span>
                    <span class="data-value" id="cursor-biome">-</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Elevation:</span>
                    <span class="data-value" id="cursor-elevation">-</span>
                </div>
            </div>
        </aside>

        <!-- Bottom Panel: Console (FIXED - now in footer like monitor) -->
        <footer>
            <div class="console-line info">&gt; Surface view initialized for <%= @celestial_body.name %></div>
            <div class="console-line info">&gt; Tileset: <%= @tileset_name || 'trident' %></div>
            <div class="console-line info">&gt; Terrain grid ready (waiting for JS init)</div>
        </footer>
    </div>

    <%= javascript_include_tag 'tileset_loader', 'surface_view', 'data-turbo-track': 'reload' %>
</body>
</html>