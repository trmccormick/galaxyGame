<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Galaxy Game - Admin Celestial Bodies</title>
    <%= stylesheet_link_tag 'admin/admin_cards', media: 'all' %>
</head>
<body>
    <div class="admin-main-container" style="display: grid; grid-template-columns: 250px 1fr; grid-template-rows: auto 1fr; min-height: 100vh;">
        <header class="admin-header">
            <h1 class="admin-title">GALAXY GAME - CELESTIAL BODIES ADMIN</h1>
            <div class="admin-header-info">
                System Status: <span class="admin-status-ok">OPERATIONAL</span> |
                Celestial Bodies: <span class="admin-highlight"><%= @total_bodies %></span> |
                Version: 1.0.0-alpha
            </div>
        </header>
        <aside class="admin-sidebar">
            <div class="admin-tool-section">
                <h3>🎯 ADMIN SECTIONS</h3>
                <a href="/admin" class="admin-tool-button">📊 Dashboard</a>
                <a href="/admin/ai_manager" class="admin-tool-button">🤖 AI Manager</a>
                <a href="/admin/solar_systems" class="admin-tool-button">☀️ Solar Systems</a>
                <a href="/admin/celestial_bodies" class="admin-tool-button admin-tool-button--active">🌍 Celestial Bodies</a>
                <a href="/admin/galaxies" class="admin-tool-button">🌌 Galaxies</a>
                <a href="/admin/organizations" class="admin-tool-button">🏢 Organizations</a>
            </div>
        </aside>
        <main class="admin-content">
            <section class="stats-section">
                <div class="stat-card">
                    <div class="stat-value"><%= @total_bodies %></div>
                    <div class="stat-label">Total Bodies</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @category_stats[:stars] %></div>
                    <div class="stat-label">Stars</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @category_stats[:planets] %></div>
                    <div class="stat-label">Planets</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @category_stats[:moons] %></div>
                    <div class="stat-label">Moons</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @category_stats[:minor_bodies] %></div>
                    <div class="stat-label">Minor Bodies</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @habitable_count %></div>
                    <div class="stat-label">Habitable</div>
                </div>
            </section>
            <section class="content-section">
                <h2>🌍 CELESTIAL BODIES CATALOG</h2>
                <div class="admin-card-grid">
                    <% @bodies.each do |body| %>
                        <div class="admin-card">
                            <div class="admin-card-header">
                                <div class="admin-card-title"><%= body.name %></div>
                                <div class="admin-card-type <%= body.body_category %>"><%= body.body_category.humanize %></div>
                            </div>
                            <div class="admin-card-description">
                                <%= body.description || "No description available" %>
                            </div>
                            <div class="admin-card-details">
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Mass:</span>
                                    <span class="admin-card-detail-value"><%= body.mass ? "#{number_to_human(body.mass, units: { unit: 'kg', thousand: 'k', million: 'M', billion: 'B', trillion: 'T' })}" : "Unknown" %></span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Radius:</span>
                                    <span class="admin-card-detail-value"><%= body.radius ? "#{(body.radius / 1000.0).round(0)} km" : "Unknown" %></span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Temperature:</span>
                                    <span class="admin-card-detail-value"><%= body.temperature ? "#{(body.temperature + 273.15).round(1)} K" : "Unknown" %></span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Atmosphere:</span>
                                    <span class="admin-card-detail-value"><%= body.atmosphere ? "Present" : "None" %></span>
                                </div>
                            </div>
                            <div class="admin-card-actions">
                                <a href="<%= monitor_admin_celestial_body_path(body) %>" class="admin-action-btn primary">🖥️ Monitor</a>
                                <a href="<%= surface_admin_celestial_body_path(body) %>" class="admin-action-btn">🌍 Surface</a>
                                <a href="<%= celestial_body_path(body) %>" class="admin-action-btn">👁️ View Details</a>
                            </div>
                        </div>
                    <% end %>
                </div>
                <% if @bodies.empty? %>
                    <div class="admin-empty-state">
                        <div class="admin-empty-icon">🌍</div>
                        <div>No celestial bodies found in the database.</div>
                        <div class="admin-empty-desc">This interface shows all celestial bodies in the game. Bodies will appear here once they are loaded into the database.</div>
                    </div>
                <% end %>
            </section>
        </main>
    </div>
</body>
</html>