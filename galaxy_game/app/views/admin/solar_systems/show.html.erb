<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Galaxy Game - Admin Solar System: <%= @solar_system.name %></title>
    <%= stylesheet_link_tag 'admin/admin_cards', media: 'all' %>
</head>
<body>
    <div class="admin-main-container" style="display: grid; grid-template-columns: 250px 1fr; grid-template-rows: auto 1fr; min-height: 100vh;">
        <header class="admin-header">
            <h1 class="admin-title">GALAXY GAME - SOLAR SYSTEM ADMIN</h1>
            <div class="admin-header-info">
                Viewing: <%= @solar_system.name %> | <%= @celestial_bodies.count %> Celestial Bodies
            </div>
        </header>
        <aside class="admin-sidebar">
            <div class="admin-tool-section">
                <h3>🎯 ADMIN SECTIONS</h3>
                <a href="/admin" class="admin-tool-button">📊 Dashboard</a>
                <a href="/admin/galaxies" class="admin-tool-button">🌌 Galaxies</a>
                <a href="/admin/solar_systems" class="admin-tool-button admin-tool-button--active">☀️ Solar Systems</a>
                <a href="/admin/celestial_bodies" class="admin-tool-button">🌍 Celestial Bodies</a>
                <a href="/admin/organizations" class="admin-tool-button">🏢 Organizations</a>
                <a href="/admin/ai_manager/missions" class="admin-tool-button">🤖 AI Manager</a>
            </div>
            <div class="admin-tool-section">
                <h3>🔗 QUICK LINKS</h3>
                <a href="/solar_systems/<%= @solar_system.id %>" class="admin-tool-button">🌍 Public View</a>
                <% if @solar_system.galaxy %>
                    <a href="/admin/galaxies/<%= @solar_system.galaxy.id %>" class="admin-tool-button">🌌 Galaxy: <%= @solar_system.galaxy.name %></a>
                <% end %>
            </div>
        </aside>
        <main class="admin-content">
            <section class="stats-section">
                <div class="stat-card">
                    <div class="stat-value"><%= @celestial_bodies.count %></div>
                    <div class="stat-label">Celestial Bodies</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @solar_system.stars.select { |star| star.solar_system_id == @solar_system.id }.count %></div>
                    <div class="stat-label">Stars</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @celestial_bodies.select { |b| b.body_type == 'terrestrial_planet' }.count %></div>
                    <div class="stat-label">Terrestrial Planets</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= @celestial_bodies.select { |b| ['gas_giant', 'ice_giant'].include?(b.body_type) }.count %></div>
                    <div class="stat-label">Gas/Ice Giants</div>
                </div>
            </section>
            <section class="content-section">
                <h2>⭐ CENTRAL STAR(S)</h2>
                <div class="admin-card-grid">
                    <% @solar_system.stars.select { |star| star.solar_system_id == @solar_system.id }.each do |star| %>
                        <div class="admin-card">
                            <div class="admin-card-header">
                                <div class="admin-card-title"><%= star.name %></div>
                                <div class="admin-card-type star"><%= star.type_of_star || 'Unknown' %></div>
                            </div>
                            <div class="admin-card-details">
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Temperature:</span>
                                    <span class="admin-card-detail-value"><%= star.temperature %> K</span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Luminosity:</span>
                                    <span class="admin-card-detail-value"><%= star.luminosity %> W</span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Age:</span>
                                    <span class="admin-card-detail-value"><%= star.age %> years</span>
                                </div>
                            </div>
                        </div>
                    <% end %>
                </div>
                <% if @solar_system.stars.select { |star| star.solar_system_id == @solar_system.id }.empty? %>
                    <div class="admin-empty-state">
                        <div class="admin-empty-icon">⭐</div>
                        <div>No stars found for this system.</div>
                    </div>
                <% end %>
            </section>
            <section class="content-section">
                <h2>🌍 CELESTIAL BODIES</h2>
                <div class="admin-card-grid">
                    <% @celestial_bodies.select { |body| body.solar_system_id == @solar_system.id }.each do |body| %>
                        <div class="admin-card">
                            <div class="admin-card-header">
                                <div class="admin-card-title"><%= body.name %></div>
                                <div class="admin-card-type <%= body.body_type %>"><%= body.body_type&.humanize || 'Unknown Type' %></div>
                            </div>
                            <div class="admin-card-details">
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Mass:</span>
                                    <span class="admin-card-detail-value"><%= body.mass ? number_with_precision(body.mass, precision: 2) : 'Unknown' %></span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Radius:</span>
                                    <span class="admin-card-detail-value"><%= body.radius ? number_with_precision(body.radius, precision: 1) : 'Unknown' %></span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Temperature:</span>
                                    <span class="admin-card-detail-value"><%= body.surface_temperature ? number_with_precision(body.surface_temperature, precision: 1) : 'Unknown' %> K</span>
                                </div>
                                <div class="admin-card-detail">
                                    <span class="admin-card-detail-label">Gravity:</span>
                                    <span class="admin-card-detail-value"><%= body.respond_to?(:surface_gravity) && body.surface_gravity.present? ? number_with_precision(body.surface_gravity, precision: 2) : 'N/A' %></span>
                                </div>
                            </div>
                            <div class="admin-card-actions">
                                <a href="/celestial_bodies/<%= body.id %>" class="admin-action-btn">View Details</a>
                                <% if body.geosphere&.terrain_map.present? %>
                                    <button class="action-btn" onclick="window.location.href='/admin/celestial_bodies/<%= body.id %>/surface'">
                                        🗺️ Surface
                                    </button>
                                <% end %>
                                <a href="/admin/celestial_bodies/<%= body.id %>/monitor" class="admin-action-btn primary">Monitor</a>
                            </div>
                        </div>
                    <% end %>
                </div>
                <% if @celestial_bodies.select { |body| body.solar_system_id == @solar_system.id }.empty? %>
                    <div class="admin-empty-state">
                        <div class="admin-empty-icon">🌍</div>
                        <div>No celestial bodies in this system.</div>
                    </div>
                <% end %>
            </section>
        </main>
    </div>
</body>
</html>