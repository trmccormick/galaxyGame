<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Galaxy Game - Admin Solar Systems</title>
    <%= stylesheet_link_tag 'admin/admin_cards', media: 'all' %>
</head>
<body>
    <div class="admin-main-container">
        <header class="admin-header">
            <h1>GALAXY GAME - SOLAR SYSTEMS ADMIN</h1>
            <div class="admin-header-info">
                System Overview: <%= @system_stats[:total_systems] %> Systems | <%= @system_stats[:total_galaxies] %> Galaxies |
                Avg <%= @system_stats[:avg_bodies_per_system] %> Bodies/System
            </div>
        </header>
        <aside class="admin-sidebar">
            <div class="admin-tool-section">
                <h3>🎯 ADMIN SECTIONS</h3>
                <a href="/admin" class="admin-tool-button">📊 Dashboard</a>
                <a href="/admin/galaxies" class="admin-tool-button">🌌 Galaxies</a>
                <a href="/admin/solar_systems" class="admin-tool-button admin-tool-button--active">☀️ Solar Systems</a>
                <a href="/admin/celestial_bodies" class="admin-tool-button">🌍 Celestial Bodies</a>
                <a href="/admin/organizations" class="admin-tool-button">🏢 Organizations</a>
                <a href="/admin/ai_manager/missions" class="admin-tool-button">🤖 AI Manager</a>
            </div>
        </aside>
        <main class="admin-content">
                        <section class="stats-section">
                            <div class="stat-card">
                                <div class="stat-value"><%= @system_stats[:total_systems] %></div>
                                <div class="stat-label">Total Systems</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-value"><%= @system_stats[:systems_with_stars] %></div>
                                <div class="stat-label">With Stars</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-value"><%= @system_stats[:habitable_systems] %></div>
                                <div class="stat-label">Habitable</div>
                            </div>
                        </section>
            <section class="content-section">
                <h2>🌌 SOLAR SYSTEMS BY GALAXY</h2>
                <% @galaxies.each do |galaxy| %>
                    <% galaxy_systems = @solar_systems.select { |s| s.galaxy_id == galaxy.id } %>
                    <% next if galaxy_systems.empty? %>
                    <div class="galaxy-section">
                        <div class="galaxy-header">
                            <%= galaxy.name %> (<%= galaxy.galaxy_type&.humanize || 'Unknown Type' %>) - <%= galaxy_systems.count %> Systems
                        </div>
                        <div class="admin-card-grid">
                            <% galaxy_systems.each do |system| %>
                                <div class="admin-card">
                                    <div class="admin-card-header">
                                        <div class="admin-card-title"><%= system.name %></div>
                                        <div class="admin-card-type star"><%= system.stars.first&.type_of_star || 'No Star' %></div>
                                    </div>
                                    <div class="admin-card-description">
                                        <%= system.celestial_bodies.count %> Bodies, <%= system.stars.count %> Stars
                                    </div>
                                    <div class="admin-card-details">
                                        <div class="admin-card-detail">
                                            <span class="admin-card-detail-label">ID:</span>
                                            <span class="admin-card-detail-value"><%= system.identifier %></span>
                                        </div>
                                        <% if system.stars.first %>
                                            <div class="admin-card-detail">
                                                <span class="admin-card-detail-label">Star:</span>
                                                <span class="admin-card-detail-value"><%= system.stars.first.name %> (<%= system.stars.first.type_of_star || 'Unknown' %>)</span>
                                            </div>
                                        <% else %>
                                            <div class="admin-card-detail">
                                                <span class="admin-card-detail-label">Star:</span>
                                                <span class="admin-card-detail-value">No central star detected</span>
                                            </div>
                                        <% end %>
                                    </div>
                                    <div class="admin-card-actions">
                                        <a class="admin-action-btn primary" href="/admin/solar_systems/<%= system.id %>">View Details</a>
                                        <a class="admin-action-btn" href="/solar_systems/<%= system.id %>">Public View</a>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    </div>
                <% end %>
                <% orphaned_systems = @solar_systems.select { |s| s.galaxy.nil? } %>
                <% if orphaned_systems.any? %>
                    <div class="galaxy-section">
                        <div class="galaxy-header">
                            Ungrouped Systems - <%= orphaned_systems.count %> Systems
                        </div>
                        <div class="admin-card-grid">
                            <% orphaned_systems.each do |system| %>
                                <div class="admin-card">
                                    <div class="admin-card-header">
                                        <div class="admin-card-title"><%= system.name %></div>
                                        <div class="admin-card-type star"><%= system.stars.first&.type_of_star || 'No Star' %></div>
                                    </div>
                                    <div class="admin-card-description">
                                        <%= system.celestial_bodies.count %> Bodies, <%= system.stars.count %> Stars
                                    </div>
                                    <div class="admin-card-details">
                                        <div class="admin-card-detail">
                                            <span class="admin-card-detail-label">ID:</span>
                                            <span class="admin-card-detail-value"><%= system.identifier %></span>
                                        </div>
                                        <% if system.stars.first %>
                                            <div class="admin-card-detail">
                                                <span class="admin-card-detail-label">Star:</span>
                                                <span class="admin-card-detail-value"><%= system.stars.first.name %> (<%= system.stars.first.type_of_star || 'Unknown' %>)</span>
                                            </div>
                                        <% else %>
                                            <div class="admin-card-detail">
                                                <span class="admin-card-detail-label">Star:</span>
                                                <span class="admin-card-detail-value">No central star detected</span>
                                            </div>
                                        <% end %>
                                    </div>
                                    <div class="admin-card-actions">
                                        <a class="admin-action-btn primary" href="/admin/solar_systems/<%= system.id %>">View Details</a>
                                        <a class="admin-action-btn" href="/solar_systems/<%= system.id %>">Public View</a>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    </div>
                <% end %>
                <% if @solar_systems.empty? %>
                    <div style="text-align: center; padding: 40px; color: #666;">
                        No solar systems found.<br>
                        <a class="tool-button" style="margin-top: 20px;" href="/simulation">
                            Initialize Simulation
                        </a>
                    </div>
                <% end %>
            </section>
        </main>
    </div>
</body>
</html>