                <%= f.submit '🚀 Generate Planetary Map', class: 'generate-button', id: 'generate-btn' %>
            <% end %>
        </div>

        <div class="generation-progress" id="progress-container">
            <h3 style="color: #ffa500; text-align: center;">🔄 Generating Map...</h3>
            <div class="progress-bar">
                <div class="progress-fill" id="progress-fill"></div>
            </div>
            <div class="progress-text" id="progress-text">Initializing AI generation...</div>
        </div>
    </div>

    <script>
        // Map selection handling
        document.querySelectorAll('.map-option').forEach(option => {
            option.addEventListener('click', function() {
                const checkbox = this.querySelector('input[type="checkbox"]');
                checkbox.checked = !checkbox.checked;
                this.classList.toggle('selected');
            });
        });

        // Form submission handling
        document.getElementById('map-generation-form').addEventListener('submit', function(e) {
            const selectedMaps = document.querySelectorAll('input[name="source_map_ids[]"]:checked');
            if (selectedMaps.length === 0) {
                e.preventDefault();
                alert('Please select at least one source map.');
                return;
            }

            // Show progress and disable form
            document.getElementById('progress-container').style.display = 'block';
            document.getElementById('generate-btn').disabled = true;
            document.getElementById('generate-btn').textContent = 'Generating...';

            // Simulate progress (in real implementation, this would be WebSocket or polling)
            let progress = 0;
            const progressInterval = setInterval(() => {
                progress += Math.random() * 15;
                if (progress > 100) progress = 100;

                document.getElementById('progress-fill').style.width = progress + '%';
                document.getElementById('progress-text').textContent =
                    progress < 30 ? 'Analyzing source maps...' :
                    progress < 60 ? 'Running AI generation...' :
                    progress < 90 ? 'Processing terrain data...' :
                    'Finalizing planetary map...';

                if (progress >= 100) {
                    clearInterval(progressInterval);
                    document.getElementById('progress-text').textContent = 'Complete! Redirecting...';
                    // Form will submit naturally
                }
            }, 1000);
        });
    </script>
</body>
</html>