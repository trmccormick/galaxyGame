        <div class="generation-form">
            <h2 class="form-title">🤖 Generate Planetary Map</h2>

            <%= form_with url: admin_map_studio_generate_map_path, method: :post, id: 'map-generation-form' do |f| %>
                <div class="form-section">
                    <h3 class="section-title">📋 Basic Information</h3>

                    <div class="form-group">
