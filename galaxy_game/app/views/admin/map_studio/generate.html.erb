<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Galaxy Game - Generate Planetary Map</title>
    <%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
    <%= stylesheet_link_tag 'application', media: 'all' %>

    <div class="studio-main-container">
        <div class="studio-content">
            <a href="<%= admin_map_studio_path %>" class="admin-tool-button" style="width: auto; display: inline-block; margin-bottom: 18px;">← Back to Map Studio</a>

            <div class="generation-form">
                <h2 class="form-title">🤖 Generate Planetary Map</h2>
                <%= form_with url: admin_map_studio_generate_map_path, method: :post, id: 'map-generation-form' do |f| %>
                    <div class="form-section">
                        <h3 class="section-title">📋 Basic Information</h3>
                        <div class="form-group">
                            <%= f.label :map_name, 'Map Name', class: 'form-label' %>
                            <%= f.text_field :map_name, class: 'form-input', placeholder: 'e.g., Earth-like Planet Alpha', required: true %>
                        </div>
                        <div class="form-group">
                            <%= f.label :target_celestial_body_id, 'Target Celestial Body (Optional)', class: 'form-label' %>
                            <%= f.select :target_celestial_body_id, options_for_select(@celestial_bodies_options), { include_blank: 'Select a celestial body...' }, class: 'form-select' %>
                            <small class="form-hint">Leave blank to generate a generic planetary map</small>
                        </div>
                        <div class="form-group">
                            <%= f.label :description, 'Description', class: 'form-label' %>
                            <%= f.text_area :description, class: 'form-textarea', placeholder: 'Describe the desired planetary characteristics, terrain types, climate, etc.' %>
                        </div>
                    </div>
                    <div class="form-section">
                        <h3 class="section-title">🗺️ Source Map Selection</h3>
                        <p class="form-hint">Choose one or more source maps to use as inspiration for the AI generation:</p>
                        <div class="map-selection" id="source-maps">
                            <% @available_source_maps.each do |map| %>
                                <div class="map-option" data-map-id="<%= map[:id] %>">
                                    <div class="map-name"><%= map[:name] %></div>
                                    <div class="map-details">
                                        <%= map[:type] %> • <%= map[:size] %> tiles<br>
                                        <%= map[:description] %>
                                    </div>
                                    <input type="checkbox" name="source_map_ids[]" value="<%= map[:id] %>" style="display: none;">
                                </div>
                            <% end %>
                        </div>
                    </div>
                    <div class="form-section">
                        <h3 class="section-title">⚙️ Generation Parameters</h3>
                        <div class="form-group">
                            <%= f.label :complexity, 'Terrain Complexity', class: 'form-label' %>
                            <%= f.select :complexity, [['Simple (Fast)', 'simple'], ['Normal', 'normal'], ['Complex (Slow)', 'complex']], { selected: 'normal' }, class: 'form-select' %>
                        </div>
                        <div class="form-group">
                            <%= f.label :biome_preference, 'Biome Focus', class: 'form-label' %>
                            <%= f.select :biome_preference, [['Balanced', 'balanced'], ['Oceanic', 'oceanic'], ['Continental', 'continental'], ['Arid', 'arid'], ['Arctic', 'arctic']], { selected: 'balanced' }, class: 'form-select' %>
                        </div>
                        <div class="form-group">
                            <%= f.label :ai_instructions, 'AI Instructions', class: 'form-label' %>
                            <%= f.text_area :ai_instructions, class: 'form-textarea', placeholder: 'Additional instructions for the AI (e.g., "Focus on realistic mountain ranges", "Include volcanic activity", "Create diverse biomes")' %>
                        </div>
                    </div>
                    <%= f.submit '🚀 Generate Planetary Map', class: 'generate-button', id: 'generate-btn' %>
                <% end %>
            </div>
            <div class="generation-progress" id="progress-container">
                <h3 class="progress-title">🔄 Generating Map...</h3>
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
                <div class="progress-text" id="progress-text">Initializing AI generation...</div>
            </div>
        </div>
    </div>
    <script>
        document.querySelectorAll('.map-option').forEach(option => {
            option.addEventListener('click', function() {
                const checkbox = this.querySelector('input[type="checkbox"]');
                checkbox.checked = !checkbox.checked;
                this.classList.toggle('selected');
            });
        });
        document.getElementById('map-generation-form').addEventListener('submit', function(e) {
            const selectedMaps = document.querySelectorAll('input[name="source_map_ids[]"]:checked');
            if (selectedMaps.length === 0) {
                e.preventDefault();
                alert('Please select at least one source map.');
                return;
            }
            document.getElementById('progress-container').style.display = 'block';
            document.getElementById('generate-btn').disabled = true;
            document.getElementById('generate-btn').textContent = 'Generating...';
            let progress = 0;
            const progressInterval = setInterval(() => {
                progress += Math.random() * 15;
                if (progress > 100) progress = 100;
                document.getElementById('progress-fill').style.width = progress + '%';
                document.getElementById('progress-text').textContent =
                    progress < 30 ? 'Analyzing source maps...' :
                    progress < 60 ? 'Running AI generation...' :
                    progress < 90 ? 'Processing terrain data...' :
                    'Finalizing planetary map...';
                if (progress >= 100) {
                    clearInterval(progressInterval);
                    document.getElementById('progress-text').textContent = 'Complete! Redirecting...';
                }
            }, 1000);
        });
    </script>
            font-size: 18px;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
            margin-top: 20px;
        }

        .generate-button:hover {
            background: #0ff;
            transform: scale(1.02);
        }

        .generate-button:disabled {
            background: #333;
            color: #666;
            cursor: not-allowed;
            transform: none;
        }

        .back-button {
            background: #222;
            color: #0f0;
            border: 1px solid #0f0;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 20px;
        }

        .back-button:hover {
            background: #0f0;
            color: #000;
        }
    </style>
</head>
<body>
    <div class="container">
