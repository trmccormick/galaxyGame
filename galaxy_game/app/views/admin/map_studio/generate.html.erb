                    </div>
                </div>

                <div class="form-section">
                    <h3 class="section-title">⚙️ Generation Parameters</h3>

                    <div class="form-group">
                        <%= f.label :complexity, 'Terrain Complexity', class: 'form-label' %>
                        <%= f.select :complexity, [['Simple (Fast)', 'simple'], ['Normal', 'normal'], ['Complex (Slow)', 'complex']], { selected: 'normal' }, class: 'form-select' %>
