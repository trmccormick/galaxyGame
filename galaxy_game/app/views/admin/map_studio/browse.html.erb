<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title>Galaxy Game - Browse Generated Maps</title>
    <%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
    <style>
        html, body {
            height: 100%;
            overflow-y: auto !important;
            overflow-x: hidden;
        }

        .container {
            min-height: 100vh;
            padding: 20px;
            box-sizing: border-box;
            padding-bottom: 50px; /* Extra padding for bottom spacing */
        }

        .maps-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .map-card {
            background: #1a1a1a;
            border: 2px solid #333;
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .map-card:hover {
            border-color: #0f0;
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0, 255, 0, 0.2);
        }

        .map-header {
            background: #222;
            padding: 15px;
            border-bottom: 1px solid #333;
        }

        .map-name {
            color: #0ff;
            font-size: 18px;
            <%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
            <%= stylesheet_link_tag 'application', media: 'all' %>

            <div class="studio-main-container">
                <div class="studio-content">
                    <a href="<%= admin_map_studio_path %>" class="admin-tool-button" style="width: auto; display: inline-block; margin-bottom: 18px;">← Back to Map Studio</a>

                    <section class="filters-section">
                        <h2 class="filters-title">🔍 Filter Generated Maps</h2>
                        <div class="filters-grid">
                            ...existing code...
                        </div>
                    </section>

                    <% if @generated_maps.any? %>
                        <section class="maps-grid">
                            <% @generated_maps.each do |map| %>
                                <div class="map-card" data-map-id="<%= map[:id] %>">
                                    <div class="map-header">
                                        <h3 class="map-name"><%= map[:name] %></h3>
                                        <div class="map-meta">
                                            Generated <%= map[:created_at] %> • Quality: <%= map[:quality_score] %>/10
                                        </div>
                                    </div>
                                    <div class="map-preview">
                                        🗺️ Planetary Map Preview
                                    </div>
                                    <div class="map-details">
                                        <div class="map-description">
                                            <%= map[:description].truncate(100) %>
                                        </div>
                                        <div class="map-stats">
                                            <span><%= map[:biome_focus] %></span>
                                            <span><%= map[:complexity] %></span>
                                        </div>
                                    </div>
                                    <div class="map-actions">
                                        <a href="<%= admin_map_studio_analyze_path(map[:id]) %>" class="admin-tool-button" style="width: auto;">📊 Analyze</a>
                                        <%= button_to '🌍 Apply', admin_map_studio_apply_map_path(map[:id]), method: :post, class: 'admin-tool-button', data: { confirm: 'Apply this map to a celestial body?' } %>
                                        <button class="admin-tool-button" style="width: auto;" onclick="previewMap(<%= map[:id] %>)">👁️ Preview</button>
                                    </div>
                                </div>
                            <% end %>
                        </section>
                        <div class="pagination" style="margin-top: 30px;">
                            <button class="admin-tool-button" style="width: auto; display: inline-block; margin-right: 8px;" onclick="changePage('prev')" <%= 'disabled' if @current_page == 1 %>>← Previous</button>
                            <span style="color: #8892b0; margin: 0 10px;">Page <%= @current_page %> of <%= @total_pages %></span>
                            <button class="admin-tool-button" style="width: auto; display: inline-block; margin-left: 8px;" onclick="changePage('next')" <%= 'disabled' if @current_page == @total_pages %>>Next →</button>
                        </div>
                    <% else %>
                        <div class="empty-state">
                            <div class="empty-title">📭 No Generated Maps</div>
                            <div class="empty-description">
                                You haven't generated any planetary maps yet. Start by creating your first AI-generated map!
                            </div>
                            <a href="<%= admin_map_studio_generate_path %>" class="admin-tool-button" style="width: auto; display: inline-block; margin-top: 20px;">🚀 Generate First Map</a>
                        </div>
                    <% end %>
                </div>

                <!-- Map Preview Modal (placeholder) -->
                <div id="map-preview-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000;">
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #1a1a1a; padding: 20px; border-radius: 10px; max-width: 80%; max-height: 80%; overflow: auto;">
                        <div style="text-align: right; margin-bottom: 10px;">
                            <button onclick="closePreview()" style="background: #f00; color: #fff; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">✕</button>
                        </div>
                        <div id="preview-content">
                            <!-- Preview content would be loaded here -->
                        </div>
                    </div>
                </div>
            </div>

            <script>
                function previewMap(mapId) {
                    document.getElementById('preview-content').innerHTML = '<p>🗺️ Map preview for ID: ' + mapId + '</p><p>Full preview functionality would be implemented here.</p>';
                    document.getElementById('map-preview-modal').style.display = 'block';
                }
                function closePreview() {
                    document.getElementById('map-preview-modal').style.display = 'none';
                }
                function changePage(direction) {
                    console.log('Changing page:', direction);
                }
                document.querySelectorAll('.filter-select').forEach(select => {
                    select.addEventListener('change', function() {
                        console.log('Filter changed:', this.id, this.value);
                    });
                });
            </script>
            color: #000;
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="<%= admin_map_studio_path %>" class="back-button">← Back to Map Studio</a>

        <div class="filters-section">
            <h2 class="filters-title">🔍 Filter Generated Maps</h2>
            <div class="filters-grid">
                <div class="filter-group">
                    <label class="filter-label">Sort By</label>
                    <select class="filter-select" id="sort-by">
                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                        <option value="name">Name (A-Z)</option>
                        <option value="quality">Quality Score</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Biome Focus</label>
                    <select class="filter-select" id="biome-filter">
                        <option value="">All Biomes</option>
                        <option value="balanced">Balanced</option>
                        <option value="oceanic">Oceanic</option>
                        <option value="continental">Continental</option>
                        <option value="arid">Arid</option>
                        <option value="arctic">Arctic</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Complexity</label>
                    <select class="filter-select" id="complexity-filter">
                        <option value="">All Complexities</option>
                        <option value="simple">Simple</option>
                        <option value="normal">Normal</option>
                        <option value="complex">Complex</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Applied Status</label>
                    <select class="filter-select" id="applied-filter">
                        <option value="">All Maps</option>
                        <option value="applied">Applied to Planets</option>
                        <option value="unapplied">Not Applied</option>
                    </select>
                </div>
            </div>
        </div>

        <% if @generated_maps.any? %>
            <div class="maps-grid">
                <% @generated_maps.each do |map| %>
                    <div class="map-card" data-map-id="<%= map[:id] %>">
                        <div class="map-header">
                            <h3 class="map-name"><%= map[:name] %></h3>
                            <div class="map-meta">
                                Generated <%= map[:created_at] %> • Quality: <%= map[:quality_score] %>/10
                            </div>
                        </div>

                        <div class="map-preview">
                            <!-- Map preview would go here -->
                            🗺️ Planetary Map Preview
                        </div>

                        <div class="map-details">
                            <div class="map-description">
                                <%= map[:description].truncate(100) %>
                            </div>
                            <div class="map-stats">
                                <span><%= map[:biome_focus] %></span>
                                <span><%= map[:complexity] %></span>
                            </div>
                        </div>

                        <div class="map-actions">
                            <a href="<%= admin_map_studio_analyze_path(map[:id]) %>" class="action-button">
                                📊 Analyze
                            </a>
                            <%= button_to '🌍 Apply', admin_map_studio_apply_map_path(map[:id]),
                                method: :post, class: 'action-button primary-action',
                                data: { confirm: 'Apply this map to a celestial body?' } %>
                            <button class="action-button" onclick="previewMap(<%= map[:id] %>)">
                                👁️ Preview
                            </button>
                        </div>
                    </div>
                <% end %>
            </div>

            <div class="pagination">
                <button class="pagination-button" onclick="changePage('prev')" <%= 'disabled' if @current_page == 1 %>>← Previous</button>
                <span style="color: #888; margin: 0 10px;">Page <%= @current_page %> of <%= @total_pages %></span>
                <button class="pagination-button" onclick="changePage('next')" <%= 'disabled' if @current_page == @total_pages %>>Next →</button>
            </div>
        <% else %>
            <div class="empty-state">
                <div class="empty-title">📭 No Generated Maps</div>
                <div class="empty-description">
                    You haven't generated any planetary maps yet. Start by creating your first AI-generated map!
                </div>
                <a href="<%= admin_map_studio_generate_path %>" class="action-button primary-action" style="display: inline-block; margin-top: 20px;">
                    🚀 Generate First Map
                </a>
            </div>
        <% end %>
    </div>

    <!-- Map Preview Modal (placeholder) -->
    <div id="map-preview-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000;">
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #1a1a1a; padding: 20px; border-radius: 10px; max-width: 80%; max-height: 80%; overflow: auto;">
            <div style="text-align: right; margin-bottom: 10px;">
                <button onclick="closePreview()" style="background: #f00; color: #fff; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">✕</button>
            </div>
            <div id="preview-content">
                <!-- Preview content would be loaded here -->
            </div>
        </div>
    </div>

    <script>
        function previewMap(mapId) {
            // In a real implementation, this would load the map preview
            document.getElementById('preview-content').innerHTML = '<p>🗺️ Map preview for ID: ' + mapId + '</p><p>Full preview functionality would be implemented here.</p>';
            document.getElementById('map-preview-modal').style.display = 'block';
        }

        function closePreview() {
            document.getElementById('map-preview-modal').style.display = 'none';
        }

        function changePage(direction) {
            // Implement pagination logic
            console.log('Changing page:', direction);
        }

        // Filter functionality
        document.querySelectorAll('.filter-select').forEach(select => {
            select.addEventListener('change', function() {
                // Implement filtering logic
                console.log('Filter changed:', this.id, this.value);
            });
        });
    </script>
</body>
</html>