<%= stylesheet_link_tag 'admin/dashboard', media: 'all' %>
<%= stylesheet_link_tag 'application', media: 'all' %>

<div class="studio-main-container">
  <header class="admin-header">
    <h1 class="studio-title">🗺️ AI Map Generation Studio</h1>
    <div class="studio-subtitle">Comprehensive planetary map creation and management system</div>
  </header>
  <main class="admin-content">
    <div class="stats-section">
      <div class="stat-card">
        <div class="stat-value"><%= @source_maps_count %></div>
        <div class="stat-label">Source Maps Available</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= @generated_maps_count %></div>
        <div class="stat-label">Generated Maps</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= @celestial_bodies_count %></div>
        <div class="stat-label">Celestial Bodies</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= @recent_generations_count %></div>
        <div class="stat-label">Recent Generations</div>
      </div>
    </div>
    <div class="action-grid">
      <div class="action-card" onclick="window.location.href='<%= admin_map_studio_generate_path %>'">
        <span class="action-icon">🤖</span>
        <div class="action-title">Generate New Map</div>
        <div class="action-description">
          Use AI to create planetary maps from FreeCiv and Civ4 source maps.
          Customize generation parameters and apply advanced terrain analysis.
        </div>
      </div>
      <div class="action-card" onclick="window.location.href='<%= admin_map_studio_browse_path %>'">
        <span class="action-icon">📚</span>
        <div class="action-title">Browse Generated Maps</div>
        <div class="action-description">
          Explore your library of AI-generated planetary maps.
          Preview, analyze quality, and manage your map collection.
        </div>
      </div>
      <div class="action-card" onclick="window.location.href='<%= admin_map_studio_browse_path %>'">
        <span class="action-icon">🌍</span>
        <div class="action-title">Apply to Planets</div>
        <div class="action-description">
          Assign generated maps to celestial bodies in your galaxy.
          Update planetary surfaces with AI-generated terrain data.
        </div>
      </div>
      <div class="action-card" onclick="window.location.href='<%= admin_ai_manager_missions_path %>'">
        <span class="action-icon">🎯</span>
        <div class="action-title">AI Mission Control</div>
        <div class="action-description">
          Monitor AI Manager missions that utilize generated maps.
          Track planetary exploration and resource discovery progress.
        </div>
      </div>
    </div>
    <div class="recent-activity">
      <div class="activity-title">📋 Recent Activity</div>
      <% if @recent_activities.any? %>
        <% @recent_activities.each do |activity| %>
          <div class="activity-item">
            <div class="activity-info">
              <div class="activity-name"><%= activity[:name] %></div>
              <div class="activity-details"><%= activity[:details] %></div>
            </div>
            <div class="activity-time"><%= activity[:time] %></div>
          </div>
        <% end %>
      <% else %>
        <div class="activity-item">
          <div class="activity-info">
            <div class="activity-name">No Recent Activity</div>
            <div class="activity-details">Start generating maps to see activity here</div>
          </div>
          <div class="activity-time">Never</div>
        </div>
      <% end %>
    </div>
    <div style="text-align: center; margin-top: 30px;">
      <a href="<%= admin_dashboard_path %>" class="admin-tool-button">← Back to Admin Dashboard</a>
    </div>
  </main>
</div>