<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Celestial Bodies - Database</title>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= stylesheet_link_tag 'admin/admin_cards', media: 'all' %>
</head>
<body>
    <div class="admin-main-container" style="display: grid; grid-template-columns: 250px 1fr; grid-template-rows: auto 1fr; min-height: 100vh;">
        <!-- Header -->
        <header class="admin-header">
            <h1 class="admin-title">CELESTIAL BODIES DATABASE</h1>
            <div class="admin-header-info">
                Total: <%= @celestial_bodies.count %> bodies |
                <%= link_to '🏠 Admin Dashboard', '/admin', class: 'admin-dashboard-link' %> |
                <%= link_to '🎮 Main Game', '/', class: 'admin-dashboard-link' %>
            </div>
        </header>

        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="admin-tool-section">
                <h3>🔍 FILTERS</h3>
                <select id="typeFilter" onchange="filterBodies()" class="admin-tool-select">
                    <option value="">All Types</option>
                    <option value="terrestrial">Terrestrial</option>
                    <option value="gas_giant">Gas Giant</option>
                    <option value="ice_giant">Ice Giant</option>
                    <option value="dwarf">Dwarf</option>
                </select>
                <select id="systemFilter" onchange="filterBodies()" class="admin-tool-select">
                    <option value="">All Systems</option>
                    <% @celestial_bodies.map(&:solar_system).compact.uniq.each do |system| %>
                        <option value="<%= system.id %>"><%= system.name %></option>
                    <% end %>
                </select>
            </div>
            <div class="admin-tool-section">
                <h3>⚙️ ACTIONS</h3>
                <button class="admin-tool-button" onclick="exportAllData()">💾 Export All</button>
                <button class="admin-tool-button" onclick="toggleView()">🔄 Toggle View</button>
            </div>
            <div class="admin-tool-section">
                <h3>📊 STATISTICS</h3>
                <div class="admin-stats">
                    <div>Total Bodies: <span class="admin-stat-value"><%= @celestial_bodies.count %></span></div>
                    <div>With Atmosphere: <span class="admin-stat-value"><%= @celestial_bodies.joins(:atmosphere).count %></span></div>
                    <div>With Biosphere: <span class="admin-stat-value"><%= @celestial_bodies.joins(:biosphere).count %></span></div>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="admin-content">
            <!-- Table View -->
            <div id="tableView">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>NAME</th>
                            <th>TYPE</th>
                            <th>SYSTEM</th>
                            <th>SIZE</th>
                            <th>GRAVITY</th>
                            <th>ATMOSPHERE</th>
                            <th>ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody id="bodiesTable">
                        <% @celestial_bodies.each do |body| %>
                        <tr class="body-row" data-type="<%= body.type %>" data-system="<%= body.solar_system_id %>">
                            <td>
                                <%= link_to body.name, celestial_body_path(body), class: 'admin-link-bold' %>
                            </td>
                            <td class="admin-type">
                                <%= body.type&.titleize || 'Unknown' %>
                            </td>
                            <td class="admin-system">
                                <%= body.solar_system&.name || 'N/A' %>
                            </td>
                            <td class="admin-size">
                                <%= number_with_precision(body.size, precision: 2) %>
                            </td>
                            <td class="admin-gravity">
                                <%= number_with_precision(body.gravity, precision: 2) %>g
                            </td>
                            <td class="admin-atmosphere">
                                <% if body.atmosphere %>
                                    <span class="admin-atmosphere-present">✓</span>
                                <% else %>
                                    <span class="admin-atmosphere-missing">✗</span>
                                <% end %>
                            </td>
                            <td class="admin-actions">
                                <%= link_to '👁️', celestial_body_path(body), class: 'admin-action-link', title: 'View' %>
                                    <%= link_to '🖥️ Monitor', celestial_body_path(body), class: 'admin-action-link', title: 'Public Monitor View' %>
                            </td>
                        </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
            <!-- Card View (hidden by default) -->
            <div id="cardView" style="display: none;">
                <div class="admin-card-grid">
                    <% @celestial_bodies.each do |body| %>
                    <div class="admin-card" data-type="<%= body.type %>" data-system="<%= body.solar_system_id %>" onclick="window.location.href='<%= celestial_body_path(body) %>'">
                        <div class="admin-card-header">
                            <h3 class="admin-card-title"><%= body.name %></h3>
                            <span class="admin-card-type <%= body.type %>"><%= body.type&.titleize || 'Unknown' %></span>
                        </div>
                        <div class="admin-card-details">
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">System:</span>
                                <span class="admin-card-detail-value"><%= body.solar_system&.name || 'N/A' %></span>
                            </div>
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">Size:</span>
                                <span class="admin-card-detail-value"><%= number_with_precision(body.size, precision: 2) %></span>
                            </div>
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">Gravity:</span>
                                <span class="admin-card-detail-value"><%= number_with_precision(body.gravity, precision: 2) %>g</span>
                            </div>
                            <% if body.atmosphere %>
                            <div class="admin-card-detail">
                                <span class="admin-card-detail-label">Atmosphere:</span>
                                <span class="admin-card-detail-value admin-atmosphere-present">Present</span>
                            </div>
                            <% end %>
                        </div>
                        <div class="admin-card-actions">
                            <%= link_to '👁️ View', celestial_body_path(body), class: 'admin-action-btn' %>
                            <%= link_to '🖥️ Monitor', celestial_body_path(body), class: 'admin-action-btn', title: 'Public Monitor View' %>
                        </div>
                    </div>
                    <% end %>
                </div>
            </div>
        </main>
    </div>

    <script>
        let currentView = 'table';
        
        function toggleView() {
            currentView = currentView === 'table' ? 'card' : 'table';
            document.getElementById('tableView').style.display = currentView === 'table' ? 'block' : 'none';
            document.getElementById('cardView').style.display = currentView === 'card' ? 'block' : 'none';
        }
        
        function filterBodies() {
            const typeFilter = document.getElementById('typeFilter').value;
            const systemFilter = document.getElementById('systemFilter').value;
            
            const rows = document.querySelectorAll('.body-row, .body-card');
            rows.forEach(row => {
                const matchesType = !typeFilter || row.dataset.type === typeFilter;
                const matchesSystem = !systemFilter || row.dataset.system === systemFilter;
                
                row.style.display = (matchesType && matchesSystem) ? '' : 'none';
            });
        }
        
        function exportAllData() {
            const bodies = <%= raw @celestial_bodies.map { |b| 
                {
                    name: b.name,
                    type: b.type,
                    system: b.solar_system&.name,
                    size: b.size,
                    gravity: b.gravity,
                    density: b.density,
                    has_atmosphere: b.atmosphere.present?
                }
            }.to_json %>;
            
            const blob = new Blob([JSON.stringify(bodies, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'celestial-bodies-export.json';
            a.click();
        }
    </script>
</body>
</html>
