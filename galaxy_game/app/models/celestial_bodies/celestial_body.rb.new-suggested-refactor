    # Callback method that runs after the object has been saved
    def run_terra_sim_after_save
      return if @simulating # Guard against re-entry
      @simulating = true
      # IMPORTANT: TerraSim::Simulator.new(self).calc_current should
      # ONLY update attributes and NOT call `save!` on `self` within this method.
      # Changes made by calc_current will be saved by the original `after_save` transaction.
      TerraSim::Simulator.new(self).calc_current
      @simulating = false
    end
  
    def simulation_relevant_changes?
      return false if new_record? # Don't run simulation for new records
      # Check if attributes relevant to simulation changed directly on CelestialBody
      # or if any associated sphere models changed
      changed.include?('mass') || changed.include?('albedo') ||
      atmosphere&.saved_change_to_id? || atmosphere&.changed? || # Check if association itself changed or atmosphere's attributes
      hydrosphere&.saved_change_to_id? || hydrosphere&.changed? ||
      geosphere&.saved_change_to_id? || geosphere&.changed? ||
      biosphere&.saved_change_to_id? || biosphere&.changed? # Assuming biosphere is also simulated
    end

    def calculate_surface_area
      return 0 unless radius.present?
      4 * Math::PI * (radius ** 2)
    end

    def calculate_escape_velocity
      return 0 unless mass.present? && radius.present?
      Math.sqrt(2 * GameConstants::GRAVITATIONAL_CONSTANT * mass.to_f / radius)
    end

    # Consolidated method to set calculated values before saving
    # These are values that should be stored in the database if they change
    def set_calculated_values_before_save
      if radius.present?
        self.surface_area = calculate_surface_area if self[:surface_area].nil? || self.saved_change_to_radius?
        self.volume = (4.0 / 3) * Math::PI * (radius ** 3) if self[:volume].nil? || self.saved_change_to_radius?
      end
      
      if mass.present? && radius.present?
        self.escape_velocity = calculate_escape_velocity if self[:escape_velocity].nil? || self.saved_change_to_mass? || self.saved_change_to_radius?
      end

